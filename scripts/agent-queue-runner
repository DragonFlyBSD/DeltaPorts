#!/usr/bin/env python3
"""Thin shim — the runner lives in dportsv3.agent.runner.

Kept as a sibling script for operators who want to invoke
``./scripts/agent-queue-runner --queue-root ...`` directly without
going through the ``dportsv3`` CLI.
"""

from __future__ import annotations

import sys
from pathlib import Path

# Add the generator package directory to sys.path so we can import
# dportsv3.* from this standalone script location.
_GENERATOR_DIR = Path(__file__).resolve().parent / "generator"
if _GENERATOR_DIR.is_dir() and str(_GENERATOR_DIR) not in sys.path:
    sys.path.insert(0, str(_GENERATOR_DIR))

from dportsv3.agent.runner import main

if __name__ == "__main__":
    sys.exit(main())
