if [ -n "${BASH_VERSION:-}" ]; then
    _dports_label="\[\033[1;34m\]dports-dev\[\033[0m\]"
    _dports_name="\[\033[1;32m\]${DPORTS_DEV_ENV}\[\033[0m\]"
    PS1="${_dports_label}:${_dports_name} \w\\$ "
else
    _dports_label=$(printf '\033[1;34mdports-dev\033[0m')
    _dports_name=$(printf '\033[1;32m%s\033[0m' "$DPORTS_DEV_ENV")
    PS1="${_dports_label}:${_dports_name} # "
fi
export PS1
showwelcome
EOF
    } > "$root_dir/root/.dports-dev-env.sh"
}

run_in_chroot() {
    root_dir=$1
    script=$2
    shift 2
    # Pass extra args as positional parameters to the chroot's /bin/sh so
    # callers can reference them via "$1"/"$2" without string-interpolation
    # injection. The "_" placeholder becomes $0 inside the inner shell.
    chroot "$root_dir" /usr/bin/env -i HOME=/root TERM="${TERM:-xterm}" PATH=/usr/local/bin:/usr/local/sbin:/bin:/sbin:/usr/bin:/usr/sbin /bin/sh -c "$script" _ "$@"
}

find_python_in_chroot() {
    root_dir=$1
    for cmd_name in $DPORTS_DEV_PYTHON_COMMANDS; do
        if run_in_chroot "$root_dir" 'command -v "$1" >/dev/null 2>&1' "$cmd_name"; then
            printf '%s\n' "$cmd_name"
            return 0
        fi
    done
    return 1
}

ensure_python_shim() {
    root_dir=$1
    if run_in_chroot "$root_dir" 'command -v python3 >/dev/null 2>&1'; then
        return 0
    fi
    python_cmd=$(find_python_in_chroot "$root_dir") || return 1
    if [ "$python_cmd" = "python3" ]; then
        return 0
    fi
    info "creating python3 shim for $python_cmd"
    run_in_chroot "$root_dir" 'cmd=$(command -v "$1") && ln -sf "$cmd" /usr/local/bin/python3' "$python_cmd"
}

bootstrap_tools() {
    root_dir=$1
    if ! run_in_chroot "$root_dir" 'command -v pkg >/dev/null 2>&1'; then
        info "pkg is not present; bootstrapping it from /usr"
        if ! run_in_chroot "$root_dir" 'cd /usr && make pkg-bootstrap >/dev/null'; then
            error "failed to bootstrap pkg inside the chroot"
            return 1
        fi
    fi
    info "bootstrapping pkg inside chroot"
    run_in_chroot "$root_dir" 'ASSUME_ALWAYS_YES=yes pkg bootstrap -yf >/dev/null 2>&1 || true'
    info "updating pkg metadata inside chroot"
    run_in_chroot "$root_dir" 'ASSUME_ALWAYS_YES=yes pkg update -f >/dev/null 2>&1 || true'
    for pkg_name in $DPORTS_DEV_TOOL_PKGS_REQUIRED; do
        info "installing required package $pkg_name"
        if ! run_in_chroot "$root_dir" 'ASSUME_ALWAYS_YES=yes pkg install -y "$1" >/dev/null' "$pkg_name"; then
            error "failed to install required package in chroot: $pkg_name"
            return 1
        fi
    done
    for pkg_name in $DPORTS_DEV_PYTHON_PKGS; do
        if find_python_in_chroot "$root_dir" >/dev/null 2>&1; then
            break
        fi
        info "installing python candidate $pkg_name"
        run_in_chroot "$root_dir" 'ASSUME_ALWAYS_YES=yes pkg install -y "$1" >/dev/null' "$pkg_name" || warn "python candidate unavailable or failed: $pkg_name"
    done
    if ! find_python_in_chroot "$root_dir" >/dev/null 2>&1; then
        error "failed to install a python3 runtime inside the chroot"
        return 1
    fi
    if ! ensure_python_shim "$root_dir"; then
        error "failed to create a python3 shim inside the chroot"
        return 1
    fi
    for pkg_name in $DPORTS_DEV_TOOL_PKGS_OPTIONAL; do
        info "installing optional package $pkg_name"
        run_in_chroot "$root_dir" 'ASSUME_ALWAYS_YES=yes pkg install -y "$1" >/dev/null' "$pkg_name" || warn "optional package unavailable or failed: $pkg_name"
    done
}

compose_inside_env() {
    root_dir=$1
    mkdir -p "$root_dir/work/artifacts/compose"
    if [ -n "$ORIGIN" ]; then
        info "running initial full compose for target $TARGET before origin-focused work on $ORIGIN"
    else
        info "running initial full compose for target $TARGET"
    fi
    run_in_chroot "$root_dir" '
        target=$1
        oracle=$2
        exec /work/DeltaPorts/dportsv3 compose \
            --target "$target" \
            --delta-root /work/DeltaPorts \
            --freebsd-root /work/freebsd-ports \
            --lock-root /work/DPorts \
            --output "/work/artifacts/compose/$target" \
            --replace-output \
            --oracle-profile "$oracle"
    ' "$TARGET" "${ORACLE_PROFILE:-off}"
}

shell_into_env() {
    env_name=$1
    refresh=${2:-0}
    load_state "$env_name"
    [ "$BACKEND" = "chroot" ] || die "unsupported backend in environment: $BACKEND"
    info "preparing shell entry for environment $env_name"
    if [ "$refresh" -eq 1 ] || [ ! -f "$ROOT_DIR/root/.dports-dev-env.sh" ]; then
        write_shell_rc "$ROOT_DIR"
    fi
    if [ "$refresh" -eq 1 ] || [ ! -x "$ROOT_DIR/usr/local/bin/regen" ]; then
        write_helper_scripts "$ROOT_DIR"
    fi
    if [ "$refresh" -eq 1 ]; then
        ensure_resolv_conf "$ROOT_DIR" 1
    fi
    prepare_root_runtime "$ROOT_DIR"
    info "entering shell for env=$env_name target=$TARGET origin=${ORIGIN:-<full-tree>}"
    info "compose root will be /work/artifacts/compose/$TARGET"
    if run_in_chroot "$ROOT_DIR" 'command -v bash >/dev/null 2>&1'; then
        exec chroot "$ROOT_DIR" /usr/bin/env -i HOME=/root TERM="${TERM:-xterm}" PATH=/usr/local/bin:/usr/local/sbin:/bin:/sbin:/usr/bin:/usr/sbin bash --noprofile --rcfile /root/.dports-dev-env.sh -i
    fi
    warn "bash is unavailable in the environment; falling back to /bin/sh"
    exec chroot "$ROOT_DIR" /usr/bin/env -i HOME=/root TERM="${TERM:-xterm}" PATH=/usr/local/bin:/usr/local/sbin:/bin:/sbin:/usr/bin:/usr/sbin /bin/sh -c '. /root/.dports-dev-env.sh; exec /bin/sh -i'
}

destroy_env() {
    env_name=$1
    if [ -f "$(state_path "$env_name")" ]; then
        load_state "$env_name"
    elif [ -d "$DPORTS_DEV_ENVS_DIR/$env_name" ]; then
        init_partial_env_state "$env_name"
        warn "environment $env_name has no state file; cleaning partial environment"
    else
        die "environment not found: $env_name"
    fi
    info "destroying environment $env_name"
    umount_if_needed "$ROOT_DIR/usr/distfiles"
    umount_if_needed "$ROOT_DIR/proc"
    umount_if_needed "$ROOT_DIR/dev"
    survivors=$(mount | awk -v root="$ROOT_DIR" 'index($0, " on " root) { print }') || survivors=
    if [ -n "$survivors" ]; then
        error "refusing to remove $ROOT_DIR; the following mounts are still present:"
        printf '%s\n' "$survivors" >&2
        die "unmount the listed paths and re-run destroy"
    fi
    clear_immutable_flags "$ROOT_DIR"
    rm -rf "$DPORTS_DEV_ENVS_DIR/$env_name"
}

list_envs() {
    if [ ! -d "$DPORTS_DEV_ENVS_DIR" ]; then
        exit 0
    fi
    for state_file in "$DPORTS_DEV_ENVS_DIR"/*/state.env; do
        [ -f "$state_file" ] || continue
        env_name=$(basename "$(dirname "$state_file")")
        unset STATE_VERSION ENV_NAME BACKEND TARGET ORIGIN DELTAPORTS_BRANCH \
            FREEBSD_BRANCH DPORTS_BRANCH HOST_DISTDIR ORACLE_PROFILE \
            SOURCE_DELTA_ROOT BASE_ARCHIVE BASE_CACHE_KEY BASE_EXTRACTED_ROOT \
            ROOT_DIR CREATED_AT
        # shellcheck disable=SC1090
        . "$state_file"
        printf '%s\t%s\t%s\t%s\n' "$env_name" "${BACKEND:-}" "${TARGET:-}" "${ORIGIN:-}"
    done
}

create_env() {
    require_root
    need_cmd curl
    need_cmd tar
    need_cmd git
    need_cmd chroot
    need_cmd mount_null
    need_cmd mount_procfs

    TARGET=
    ORIGIN=
    SOURCE_DELTA_ROOT=$REPO_ROOT
    DELTAPORTS_BRANCH=$DPORTS_DEV_DELTAPORTS_BRANCH
    BACKEND=chroot
    FREEBSD_BRANCH=
    DPORTS_BRANCH=$DPORTS_DEV_DPORTS_BRANCH
    HOST_DISTDIR=$DPORTS_DEV_HOST_DISTDIR
    ORACLE_PROFILE=off
    ENV_NAME=
    auto_shell=0
    allow_dirty=0
    skip_initial_compose=0

    while [ "$#" -gt 0 ]; do
        case "$1" in
            --name)
                [ "$#" -ge 2 ] || die "--name requires a value"
                ENV_NAME=$2
                shift 2
                ;;
            --target)
                [ "$#" -ge 2 ] || die "--target requires a value"
                TARGET=$2
                shift 2
                ;;
            --origin)
                [ "$#" -ge 2 ] || die "--origin requires a value"
                ORIGIN=$2
                shift 2
                ;;
            --delta-root)
                [ "$#" -ge 2 ] || die "--delta-root requires a value"
                SOURCE_DELTA_ROOT=$2
                shift 2
                ;;
            --backend)
                [ "$#" -ge 2 ] || die "--backend requires a value"
                BACKEND=$2
                shift 2
                ;;
            --freebsd-branch)
                [ "$#" -ge 2 ] || die "--freebsd-branch requires a value"
                FREEBSD_BRANCH=$2
                shift 2
                ;;
            --dports-branch)
                [ "$#" -ge 2 ] || die "--dports-branch requires a value"
                DPORTS_BRANCH=$2
                shift 2
                ;;
            --shell)
                auto_shell=1
                shift
                ;;
            --allow-dirty)
                allow_dirty=1
                shift
                ;;
            --no-initial-compose)
                skip_initial_compose=1
                shift
                ;;
            --oracle-profile)
                [ "$#" -ge 2 ] || die "--oracle-profile requires a value"
                ORACLE_PROFILE=$2
                shift 2
                ;;
            --help|-h)
                usage
                exit 0
                ;;
            *)
                die "unknown create option: $1"
                ;;
        esac
    done

    [ -n "$TARGET" ] || die "--target is required"
    [ "$BACKEND" = "chroot" ] || die "unsupported backend: $BACKEND"
    case "$ORACLE_PROFILE" in
        off|local|ci) ;;
        *) die "--oracle-profile must be one of: off, local, ci" ;;
    esac
    [ -d "$SOURCE_DELTA_ROOT" ] || die "Delta root does not exist: $SOURCE_DELTA_ROOT"
    [ -f "$SOURCE_DELTA_ROOT/dportsv3" ] || die "Delta root does not look like this repo: $SOURCE_DELTA_ROOT"
    git -C "$SOURCE_DELTA_ROOT" rev-parse --git-dir >/dev/null 2>&1 || die "Delta root is not a git checkout: $SOURCE_DELTA_ROOT"

    host_dirty=$(git -C "$SOURCE_DELTA_ROOT" status --porcelain 2>/dev/null || true)
    if [ -n "$host_dirty" ]; then
        warn "host DeltaPorts checkout has uncommitted changes; only committed state will appear in the env"
        if [ "$allow_dirty" -ne 1 ]; then
            error "refusing to create env from a dirty host checkout (pass --allow-dirty to proceed)"
            error "summary of dirty paths:"
            printf '%s\n' "$host_dirty" | head -20 >&2
            die "commit/stash host edits, or re-run with --allow-dirty"
        fi
    fi

    if [ -z "$FREEBSD_BRANCH" ]; then
        FREEBSD_BRANCH=$(target_to_branch "$TARGET")
    fi
    if [ -z "$ENV_NAME" ]; then
        ENV_NAME=$(default_env_name "$TARGET" "$ORIGIN")
    fi

    env_dir="$DPORTS_DEV_ENVS_DIR/$ENV_NAME"
    ROOT_DIR=$(root_path "$ENV_NAME")
    [ ! -e "$env_dir" ] || die "environment already exists: $ENV_NAME"

    step 1 7 "Resolving latest DragonFly world asset"
    asset=$(fetch_latest_world_asset)

    step 2 7 "Preparing cached DragonFly base root"
    BASE_CACHE_KEY=${asset%.tar.gz}
    acquire_cache_lock "world-$BASE_CACHE_KEY"
    BASE_ARCHIVE=$(ensure_base_archive "$asset")
    BASE_EXTRACTED_ROOT=$(ensure_base_extracted "$BASE_CACHE_KEY" "$BASE_ARCHIVE")
    release_cache_lock "world-$BASE_CACHE_KEY"

    step 3 7 "Refreshing cached repo mirrors"
    acquire_cache_lock mirror-deltaports
    DELTAPORTS_MIRROR=$(ensure_local_git_mirror deltaports "$SOURCE_DELTA_ROOT")
    release_cache_lock mirror-deltaports
    acquire_cache_lock mirror-freebsd-ports
    FREEBSD_MIRROR=$(ensure_remote_git_mirror freebsd-ports "$DPORTS_DEV_FREEBSD_PORTS_URL")
    release_cache_lock mirror-freebsd-ports
    acquire_cache_lock mirror-DPorts
    DPORTS_MIRROR=$(ensure_remote_git_mirror DPorts "$DPORTS_DEV_DPORTS_URL")
    release_cache_lock mirror-DPorts

    step 4 7 "Creating throwaway chroot root"
    copy_base_root "$BASE_EXTRACTED_ROOT" "$ROOT_DIR"

    step 5 7 "Seeding env-local source trees and writing environment state"
    prepare_root_runtime "$ROOT_DIR"
    seed_deltaports_checkout "$DELTAPORTS_MIRROR" "$DELTAPORTS_BRANCH" "$ROOT_DIR/work/DeltaPorts"
    seed_freebsd_checkout "$FREEBSD_MIRROR" "$FREEBSD_BRANCH" "$ROOT_DIR/work/freebsd-ports"
    export_git_tree_from_ref DPorts "$DPORTS_MIRROR" "$DPORTS_BRANCH" "$ROOT_DIR/work/DPorts"
    mkdir -p "$ROOT_DIR/work/artifacts/compose"
    CREATED_AT=$(date -u '+%Y-%m-%dT%H:%M:%SZ')
    write_shell_rc "$ROOT_DIR"
    write_helper_scripts "$ROOT_DIR"
    write_state "$ENV_NAME"

    step 6 7 "Bootstrapping developer tools inside chroot"
    bootstrap_failed=0
    if ! bootstrap_tools "$ROOT_DIR"; then
        bootstrap_failed=1
        warn "bootstrap failed; environment retained for manual investigation"
    fi

    compose_failed=0
    if [ "$bootstrap_failed" -eq 1 ]; then
        step 7 7 "Skipping initial compose because bootstrap failed"
        compose_failed=1
    elif [ "$skip_initial_compose" -eq 1 ]; then
        step 7 7 "Skipping initial compose (--no-initial-compose); run 'regen' inside the shell when ready"
    else
        step 7 7 "Running initial compose"
        if ! compose_inside_env "$ROOT_DIR"; then
            compose_failed=1
            warn "compose failed; environment retained for manual investigation"
        fi
    fi

    if [ "$auto_shell" -eq 1 ]; then
        if [ "$bootstrap_failed" -eq 1 ]; then
            warn "opening shell despite bootstrap failure because --shell was requested"
        elif [ "$compose_failed" -eq 1 ]; then
            warn "opening shell despite compose failure because --shell was requested"
        fi
        shell_into_env "$ENV_NAME"
    fi

    if [ "$bootstrap_failed" -eq 1 ] || [ "$compose_failed" -eq 1 ]; then
        exit 1
    fi

    info "environment ready: $ENV_NAME"
}

main() {
    ensure_dirs
    action=${1:-}
    case "$action" in
        create)
            shift
            case "${1:-}" in
                --help|-h)
                    usage
                    exit 0
                    ;;
            esac
            create_env "$@"
            ;;
        shell)
            shift
            shell_refresh=0
            shell_name=
            while [ "$#" -gt 0 ]; do
                case "$1" in
                    --help|-h)
                        usage
                        exit 0
                        ;;
                    --refresh)
                        shell_refresh=1
                        shift
                        ;;
                    --)
                        shift
                        ;;
                    -*)
                        die "unknown shell option: $1"
                        ;;
                    *)
                        [ -z "$shell_name" ] || die "shell takes a single environment name"
                        shell_name=$1
                        shift
                        ;;
                esac
            done
            [ -n "$shell_name" ] || { usage; exit 0; }
            require_root
            shell_into_env "$shell_name" "$shell_refresh"
            ;;
        destroy)
            require_root
            case "${2:-}" in
                --help|-h|'')
                    usage
                    exit 0
                    ;;
            esac
            [ "$#" -eq 2 ] || die "destroy requires an environment name"
            destroy_env "$2"
            ;;
        list)
            list_envs
            ;;
        --help|-h|help|'')
            usage
            ;;
        *)
            die "unknown action: $action"
            ;;
    esac
}

main "$@"
