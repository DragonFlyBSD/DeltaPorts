        printf 'export DPORTS_DEV_ENV=%s\n' "$(shell_quote "$ENV_NAME")"
        printf 'export DPORTS_TARGET=%s\n' "$(shell_quote "$TARGET")"
        printf 'export DPORTS_ORIGIN=%s\n' "$(shell_quote "$ORIGIN")"
        printf 'export DPORTS_COMPOSE_ROOT=%s\n' "$(shell_quote "/work/artifacts/compose/$TARGET")"
        printf 'export DPORTS_LOCK_ROOT=%s\n' '/work/DPorts'
        printf 'export DPORTS_ORACLE_PROFILE=%s\n' "$(shell_quote "${ORACLE_PROFILE:-off}")"
        printf 'export DISTDIR=%s\n' '/usr/distfiles'
        printf 'export DPORTS_DOC_USER_GUIDE=%s\n' 'https://github.com/DragonFlyBSD/DeltaPorts/blob/master/docs/dportsv3-user-guide.md'
        printf 'export DPORTS_DOC_DEV_ENV=%s\n' 'https://github.com/DragonFlyBSD/DeltaPorts/blob/master/docs/dev-chroot-environment.md'
        printf 'export PATH=%s\n' '/usr/local/bin:/usr/local/sbin:/bin:/sbin:/usr/bin:/usr/sbin'
        cat <<'EOF'

