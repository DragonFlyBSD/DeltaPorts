#!/bin/sh

set -eu

SELF_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
REPO_ROOT=$(CDPATH= cd -- "$SELF_DIR/../.." && pwd)

DPORTS_DEV_CACHE_ROOT=${DPORTS_DEV_CACHE_ROOT:-${HOME}/.cache/dports-dev}
DPORTS_DEV_ENVS_DIR=${DPORTS_DEV_ENVS_DIR:-$DPORTS_DEV_CACHE_ROOT/envs}
DPORTS_DEV_BASE_DIR=${DPORTS_DEV_BASE_DIR:-$DPORTS_DEV_CACHE_ROOT/base-extracted}
DPORTS_DEV_DOWNLOAD_DIR=${DPORTS_DEV_DOWNLOAD_DIR:-$DPORTS_DEV_CACHE_ROOT/base-downloads}
DPORTS_DEV_REPOS_DIR=${DPORTS_DEV_REPOS_DIR:-$DPORTS_DEV_CACHE_ROOT/repos}
DPORTS_DEV_AVALON_RELEASES_URL=${DPORTS_DEV_AVALON_RELEASES_URL:-https://avalon.dragonflybsd.org/snapshots/x86_64/assets/releases/}
DPORTS_DEV_FREEBSD_PORTS_URL=${DPORTS_DEV_FREEBSD_PORTS_URL:-https://git.FreeBSD.org/ports.git}
DPORTS_DEV_DPORTS_URL=${DPORTS_DEV_DPORTS_URL:-https://github.com/DragonFlyBSD/DPorts.git}
DPORTS_DEV_DELTAPORTS_BRANCH=${DPORTS_DEV_DELTAPORTS_BRANCH:-master}
DPORTS_DEV_DPORTS_BRANCH=${DPORTS_DEV_DPORTS_BRANCH:-staged}
DPORTS_DEV_HOST_DISTDIR=${DPORTS_DEV_HOST_DISTDIR:-/usr/distfiles}
DPORTS_DEV_TOOL_PKGS_REQUIRED=${DPORTS_DEV_TOOL_PKGS_REQUIRED:-bash curl git patch jq}
DPORTS_DEV_PYTHON_PKGS=${DPORTS_DEV_PYTHON_PKGS:-python3 python313 python312 python311}
DPORTS_DEV_TOOL_PKGS_OPTIONAL=${DPORTS_DEV_TOOL_PKGS_OPTIONAL:-python311 python312 python313 py311-pip py312-pip py313-pip genpatch}
DPORTS_DEV_PYTHON_COMMANDS=${DPORTS_DEV_PYTHON_COMMANDS:-python3 python3.13 python3.12 python3.11}

usage() {
    cat <<'EOF'
usage: scripts/tools/dports-dev-env ACTION [options]

Actions:
  create   Create one throwaway DragonFly chroot dev environment
  shell    Enter one existing environment via chroot
  destroy  Unmount and remove one environment
  list     List known environments

create options:
  --name NAME          Environment name (default: derived from target/origin)
  --target TARGET      Compose target, e.g. @2026Q2 (required)
  --origin ORIGIN      Optional selected origin, e.g. editors/vim
  --delta-root PATH    Host DeltaPorts checkout used to refresh the cache mirror (default: this repo)
  --backend NAME       Backend name (default: chroot)
  --freebsd-branch BR  Override FreeBSD branch (default: derived from target)
  --dports-branch BR   Override DPorts branch (default: staged)
  --shell              Enter the shell after creation succeeds

shell options:
  NAME                 Environment name

destroy options:
  NAME                 Environment name

Environment variables:
  DPORTS_DEV_CACHE_ROOT
  DPORTS_DEV_AVALON_RELEASES_URL
  DPORTS_DEV_FREEBSD_PORTS_URL
  DPORTS_DEV_DPORTS_URL
  DPORTS_DEV_DELTAPORTS_BRANCH
  DPORTS_DEV_DPORTS_BRANCH
  DPORTS_DEV_HOST_DISTDIR
  DPORTS_DEV_TOOL_PKGS_REQUIRED
  DPORTS_DEV_PYTHON_PKGS
  DPORTS_DEV_PYTHON_COMMANDS
  DPORTS_DEV_TOOL_PKGS_OPTIONAL
EOF
}

log_line() {
    level=$1
    shift
    printf '%s: %s\n' "$level" "$*" >&2
}

info() {
    log_line INFO "$@"
}

warn() {
    log_line WARN "$@"
}

error() {
    log_line ERROR "$@"
}

die() {
    error "$*"
    exit 1
}

step() {
    current=$1
    total=$2
    shift 2
    info "[$current/$total] $*"
}

need_cmd() {
    command -v "$1" >/dev/null 2>&1 || die "required command not found: $1"
}

require_root() {
    [ "$(id -u)" -eq 0 ] || die "must run as root"
}

clear_immutable_flags() {
    path=$1
    if [ ! -e "$path" ]; then
        return 0
    fi
    if ! command -v chflags >/dev/null 2>&1; then
        return 0
    fi
    info "clearing immutable flags under $path"
    chflags -R noschg,nouchg "$path" 2>/dev/null || warn "failed to clear immutable flags under $path"
}

ensure_dirs() {
    mkdir -p "$DPORTS_DEV_CACHE_ROOT" "$DPORTS_DEV_ENVS_DIR" "$DPORTS_DEV_BASE_DIR" \
        "$DPORTS_DEV_DOWNLOAD_DIR" "$DPORTS_DEV_REPOS_DIR"
}

sanitize_name() {
    printf '%s' "$1" | tr '/:@ ' '____' | tr -cd 'A-Za-z0-9._-'
}

target_to_branch() {
    case "$1" in
        @main) printf '%s\n' main ;;
        @20[0-9][0-9]Q[1-4]) printf '%s\n' "${1#@}" ;;
        *) die "unsupported target: $1" ;;
    esac
}

default_env_name() {
    target=$1
    origin=${2:-}
    base=$(sanitize_name "${target#@}")
    if [ -n "$origin" ]; then
        printf '%s\n' "${base}-$(sanitize_name "$origin")"
    else
        printf '%s\n' "$base"
    fi
}

state_path() {
    printf '%s/state.env\n' "$DPORTS_DEV_ENVS_DIR/$1"
}

shell_quote() {
    printf "'"
    printf '%s' "$1" | sed "s/'/'\\''/g"
    printf "'"
}

root_path() {
    printf '%s/root\n' "$DPORTS_DEV_ENVS_DIR/$1"
}

load_state() {
    env_name=$1
    state_file=$(state_path "$env_name")
    [ -f "$state_file" ] || die "environment not found: $env_name"
    # shellcheck disable=SC1090
    . "$state_file"
    : "${DELTAPORTS_BRANCH:=$DPORTS_DEV_DELTAPORTS_BRANCH}"
    : "${DPORTS_BRANCH:=$DPORTS_DEV_DPORTS_BRANCH}"
    : "${HOST_DISTDIR:=$DPORTS_DEV_HOST_DISTDIR}"
}

init_partial_env_state() {
    env_name=$1
    ENV_NAME=$env_name
    BACKEND=chroot
    TARGET=
    ORIGIN=
    DELTAPORTS_BRANCH=
    FREEBSD_BRANCH=
    DPORTS_BRANCH=
    HOST_DISTDIR=
    SOURCE_DELTA_ROOT=
    BASE_ARCHIVE=
    BASE_CACHE_KEY=
    BASE_EXTRACTED_ROOT=
    ROOT_DIR=$(root_path "$env_name")
    CREATED_AT=
}

write_state() {
    env_name=$1
    env_dir=$DPORTS_DEV_ENVS_DIR/$env_name
    mkdir -p "$env_dir"
    state_file=$(state_path "$env_name")
    tmp_file="$state_file.tmp.$$"
    umask 077
    cat > "$tmp_file" <<EOF
ENV_NAME=$(shell_quote "$ENV_NAME")
BACKEND=$(shell_quote "$BACKEND")
TARGET=$(shell_quote "$TARGET")
ORIGIN=$(shell_quote "$ORIGIN")
DELTAPORTS_BRANCH=$(shell_quote "$DELTAPORTS_BRANCH")
FREEBSD_BRANCH=$(shell_quote "$FREEBSD_BRANCH")
DPORTS_BRANCH=$(shell_quote "$DPORTS_BRANCH")
HOST_DISTDIR=$(shell_quote "$HOST_DISTDIR")
SOURCE_DELTA_ROOT=$(shell_quote "$SOURCE_DELTA_ROOT")
BASE_ARCHIVE=$(shell_quote "$BASE_ARCHIVE")
BASE_CACHE_KEY=$(shell_quote "$BASE_CACHE_KEY")
BASE_EXTRACTED_ROOT=$(shell_quote "$BASE_EXTRACTED_ROOT")
ROOT_DIR=$(shell_quote "$ROOT_DIR")
CREATED_AT=$(shell_quote "$CREATED_AT")
EOF
    mv -f "$tmp_file" "$state_file"
}

fetch_latest_world_asset() {
    listing=$(curl -fsSL "$DPORTS_DEV_AVALON_RELEASES_URL") || die "failed to fetch Avalon listing"
    asset=$(printf '%s\n' "$listing" | grep -Eo 'DragonFly-x86_64-[^"<>[:space:]]*\.world\.tar\.gz' | sort -u | sort | tail -n 1)
    [ -n "$asset" ] || die "could not locate DragonFly x86_64 world asset in Avalon listing"
    printf '%s\n' "$asset"
}

ensure_base_archive() {
    asset=$1
    archive_path="$DPORTS_DEV_DOWNLOAD_DIR/$asset"
    if [ ! -f "$archive_path" ]; then
        info "downloading world archive $asset"
        curl -fL "$DPORTS_DEV_AVALON_RELEASES_URL/$asset" -o "$archive_path"
    else
        info "reusing cached world archive $archive_path"
    fi
    printf '%s\n' "$archive_path"
}

ensure_base_extracted() {
    cache_key=$1
    archive_path=$2
    extracted="$DPORTS_DEV_BASE_DIR/$cache_key"
    if [ ! -d "$extracted" ]; then
        tmp_dir="$extracted.tmp.$$"
        rm -rf "$tmp_dir"
        mkdir -p "$tmp_dir"
        info "extracting cached base root from $archive_path"
        tar -xpf "$archive_path" -C "$tmp_dir"
        mv "$tmp_dir" "$extracted"
    else
        info "reusing extracted base root $extracted"
    fi
    printf '%s\n' "$extracted"
}

copy_tree() {
    src=$1
    dst=$2
    shift 2
    [ ! -e "$dst" ] || die "destination already exists: $dst"
    mkdir -p "$dst"
    tar_args=
    for pattern in "$@"; do
        tar_args="$tar_args --exclude=$pattern"
    done
    # shellcheck disable=SC2086
    tar -C "$src" $tar_args -cpf - . | tar -C "$dst" -xpf -
}

copy_base_root() {
    src=$1
    dst=$2
    info "copying cached base into $dst"
    copy_tree "$src" "$dst"
}

ensure_remote_git_mirror() {
    name=$1
    url=$2
    mirror="$DPORTS_DEV_REPOS_DIR/$name.git"
    if [ ! -d "$mirror" ]; then
        info "creating $name mirror at $mirror"
        git clone --mirror "$url" "$mirror"
    else
        info "updating $name mirror $mirror"
        git --git-dir="$mirror" fetch --prune origin
    fi
    printf '%s\n' "$mirror"
}

ensure_local_git_mirror() {
    name=$1
    source_repo=$2
    mirror="$DPORTS_DEV_REPOS_DIR/$name.git"
    if [ ! -d "$mirror" ]; then
        info "creating $name mirror from $source_repo"
        git clone --mirror "$source_repo" "$mirror"
    else
        info "updating $name mirror from $source_repo"
        git --git-dir="$mirror" remote set-url origin "$source_repo"
        git --git-dir="$mirror" fetch --prune origin '+refs/*:refs/*'
    fi
    printf '%s\n' "$mirror"
}

seed_deltaports_checkout() {
    mirror=$1
    branch=$2
    dest=$3
    info "cloning DeltaPorts branch $branch into $dest"
    git clone --single-branch --branch "$branch" "$mirror" "$dest" >&2
    if [ -d "$dest/scripts/generator/.venv" ]; then
        rm -rf "$dest/scripts/generator/.venv"
    fi
}

seed_freebsd_checkout() {
    mirror=$1
    branch=$2
    dest=$3
    info "cloning freebsd-ports branch $branch into $dest"
    git clone --single-branch --branch "$branch" "$mirror" "$dest" >&2
}

export_git_tree_from_ref() {
    label=$1
    mirror=$2
    branch=$3
    dest=$4
    if git --git-dir="$mirror" rev-parse --verify "refs/heads/$branch" >/dev/null 2>&1; then
        ref="refs/heads/$branch"
    elif git --git-dir="$mirror" rev-parse --verify "refs/remotes/origin/$branch" >/dev/null 2>&1; then
        ref="refs/remotes/origin/$branch"
    else
        die "branch not found in $label mirror: $branch"
    fi
    info "exporting $label branch $branch into $dest"
    mkdir -p "$dest"
    git --git-dir="$mirror" archive "$ref" | tar -C "$dest" -xpf -
}

mount_if_needed() {
    src=$1
    dst=$2
    mkdir -p "$dst"
    if mount | grep -F " on $dst " >/dev/null 2>&1; then
        info "mount already present at $dst"
        return 0
    fi
    info "mounting $src at $dst"
    mount_null "$src" "$dst"
}

umount_if_needed() {
    path=$1
    if mount | grep -F " on $path " >/dev/null 2>&1; then
        info "unmounting $path"
        umount "$path"
    fi
}

prepare_root_runtime() {
    root_dir=$1
    mkdir -p "$root_dir/dev" "$root_dir/proc" "$root_dir/work"
    if [ -f /etc/resolv.conf ]; then
        mkdir -p "$root_dir/etc"
        cp /etc/resolv.conf "$root_dir/etc/resolv.conf"
    fi
    mount_if_needed /dev "$root_dir/dev"
    if ! mount | grep -F " on $root_dir/proc " >/dev/null 2>&1; then
        info "mounting procfs at $root_dir/proc"
        mount_procfs proc "$root_dir/proc"
    fi
    if [ -n "$HOST_DISTDIR" ] && [ -d "$HOST_DISTDIR" ]; then
        mount_if_needed "$HOST_DISTDIR" "$root_dir/usr/distfiles"
    fi
}

write_shell_rc() {
    root_dir=$1
    mkdir -p "$root_dir/root"
    cat > "$root_dir/root/.dports-dev-env.sh" <<EOF
export DELTAPORTS_ROOT=/work/DeltaPorts
export FREEBSD_PORTS_ROOT=/work/freebsd-ports
export DPORTS_DEV_ENV=$ENV_NAME
export DPORTS_TARGET=$TARGET
export DPORTS_ORIGIN=$ORIGIN
export DPORTS_COMPOSE_ROOT=/work/artifacts/compose/$TARGET
export DPORTS_LOCK_ROOT=/work/DPorts
export DISTDIR=/usr/distfiles
export DPORTS_DOC_USER_GUIDE=https://github.com/DragonFlyBSD/DeltaPorts/blob/master/docs/dportsv3-user-guide.md
export DPORTS_DOC_DEV_ENV=https://github.com/DragonFlyBSD/DeltaPorts/blob/master/docs/dev-chroot-environment.md
export PATH=/usr/local/bin:/usr/local/sbin:/bin:/sbin:/usr/bin:/usr/sbin

if [ -n "\$DPORTS_ORIGIN" ] && [ -d "\$DPORTS_COMPOSE_ROOT/\$DPORTS_ORIGIN" ]; then
    cd "\$DPORTS_COMPOSE_ROOT/\$DPORTS_ORIGIN"
elif [ -d "\$DPORTS_COMPOSE_ROOT" ]; then
    cd "\$DPORTS_COMPOSE_ROOT"
else
    cd /work/DeltaPorts
fi

regen() {
    if [ -n "\$DPORTS_ORIGIN" ]; then
        /work/DeltaPorts/dportsv3 compose --target "\$DPORTS_TARGET" --delta-root /work/DeltaPorts --freebsd-root /work/freebsd-ports --lock-root "\$DPORTS_LOCK_ROOT" --output "\$DPORTS_COMPOSE_ROOT" --replace-output --oracle-profile off --origin "\$DPORTS_ORIGIN"
    else
        /work/DeltaPorts/dportsv3 compose --target "\$DPORTS_TARGET" --delta-root /work/DeltaPorts --freebsd-root /work/freebsd-ports --lock-root "\$DPORTS_LOCK_ROOT" --output "\$DPORTS_COMPOSE_ROOT" --replace-output --oracle-profile off
    fi
}

reapply() {
    if [ -z "\$DPORTS_ORIGIN" ]; then
        printf '%s\n' 'reapply requires the environment to have been created with --origin' >&2
        return 1
    fi
    /work/DeltaPorts/dportsv3 dsl apply "/work/DeltaPorts/ports/\$DPORTS_ORIGIN/overlay.dops" --port-root "\$DPORTS_COMPOSE_ROOT/\$DPORTS_ORIGIN" --target "\$DPORTS_TARGET" --oracle-profile off
}

showenv() {
    env | grep '^DPORTS_' | sort
}

showwelcome() {
    printf '%s\n' "dports-dev: \$DPORTS_DEV_ENV"
    printf '%s\n' "Target: \$DPORTS_TARGET"
    if [ -n "\$DPORTS_ORIGIN" ]; then
        printf '%s\n' "Origin: \$DPORTS_ORIGIN"
    else
        printf '%s\n' 'Origin: full tree'
    fi
    printf '%s\n' 'Paths:'
    printf '  DeltaPorts: %s\n' "\$DELTAPORTS_ROOT"
    printf '  FreeBSD ports: %s\n' "\$FREEBSD_PORTS_ROOT"
    printf '  DPorts: %s\n' "\$DPORTS_LOCK_ROOT"
    printf '  Compose: %s\n' "\$DPORTS_COMPOSE_ROOT"
    printf '  Distfiles: %s\n' "\$DISTDIR"
    if [ -n "\$DPORTS_ORIGIN" ]; then
        printf '  Composed origin: %s\n' "\$DPORTS_COMPOSE_ROOT/\$DPORTS_ORIGIN"
        printf '  Overlay: %s\n' "\$DELTAPORTS_ROOT/ports/\$DPORTS_ORIGIN"
    fi
    printf '%s\n' 'Docs:'
    printf '  %s\n' "\$DPORTS_DOC_USER_GUIDE"
    printf '  %s\n' "\$DPORTS_DOC_DEV_ENV"
    printf '%s\n' 'Helpers: regen reapply showenv'
}

if [ -n "\${BASH_VERSION:-}" ]; then
    _dports_label="\[\033[1;34m\]dports-dev\[\033[0m\]"
    _dports_name="\[\033[1;32m\]\${DPORTS_DEV_ENV}\[\033[0m\]"
    PS1="\${_dports_label}:\${_dports_name} \w\\$ "
else
    _dports_label=\$(printf '\033[1;34mdports-dev\033[0m')
    _dports_name=\$(printf '\033[1;32m%s\033[0m' "\$DPORTS_DEV_ENV")
    PS1="\${_dports_label}:\${_dports_name} # "
fi
export PS1
showwelcome
EOF
}

run_in_chroot() {
    root_dir=$1
    shift
    chroot "$root_dir" /usr/bin/env -i HOME=/root TERM="${TERM:-xterm}" PATH=/usr/local/bin:/usr/local/sbin:/bin:/sbin:/usr/bin:/usr/sbin /bin/sh -c "$*"
}

find_python_in_chroot() {
    root_dir=$1
    for cmd_name in $DPORTS_DEV_PYTHON_COMMANDS; do
        if run_in_chroot "$root_dir" "command -v $cmd_name >/dev/null 2>&1"; then
            printf '%s\n' "$cmd_name"
            return 0
        fi
    done
    return 1
}

ensure_python_shim() {
    root_dir=$1
    if run_in_chroot "$root_dir" 'command -v python3 >/dev/null 2>&1'; then
        return 0
    fi
    python_cmd=$(find_python_in_chroot "$root_dir") || return 1
    if [ "$python_cmd" = "python3" ]; then
        return 0
    fi
    info "creating python3 shim for $python_cmd"
    run_in_chroot "$root_dir" "cmd=\$(command -v $python_cmd) && ln -sf \"\$cmd\" /usr/local/bin/python3"
}

bootstrap_tools() {
    root_dir=$1
    if ! run_in_chroot "$root_dir" 'command -v pkg >/dev/null 2>&1'; then
        info "pkg is not present; bootstrapping it from /usr"
        run_in_chroot "$root_dir" 'cd /usr && make pkg-bootstrap >/dev/null' || die "failed to bootstrap pkg inside the chroot"
    fi
    info "bootstrapping pkg inside chroot"
    run_in_chroot "$root_dir" 'ASSUME_ALWAYS_YES=yes pkg bootstrap -yf >/dev/null 2>&1 || true'
    info "updating pkg metadata inside chroot"
    run_in_chroot "$root_dir" 'ASSUME_ALWAYS_YES=yes pkg update -f >/dev/null 2>&1 || true'
    for pkg_name in $DPORTS_DEV_TOOL_PKGS_REQUIRED; do
        info "installing required package $pkg_name"
        run_in_chroot "$root_dir" "ASSUME_ALWAYS_YES=yes pkg install -y $pkg_name >/dev/null" || die "failed to install required package in chroot: $pkg_name"
    done
    for pkg_name in $DPORTS_DEV_PYTHON_PKGS; do
        if find_python_in_chroot "$root_dir" >/dev/null 2>&1; then
            break
        fi
        info "installing python candidate $pkg_name"
        run_in_chroot "$root_dir" "ASSUME_ALWAYS_YES=yes pkg install -y $pkg_name >/dev/null" || warn "python candidate unavailable or failed: $pkg_name"
    done
    find_python_in_chroot "$root_dir" >/dev/null 2>&1 || die "failed to install a python3 runtime inside the chroot"
    ensure_python_shim "$root_dir" || die "failed to create a python3 shim inside the chroot"
    for pkg_name in $DPORTS_DEV_TOOL_PKGS_OPTIONAL; do
        info "installing optional package $pkg_name"
        run_in_chroot "$root_dir" "ASSUME_ALWAYS_YES=yes pkg install -y $pkg_name >/dev/null" || warn "optional package unavailable or failed: $pkg_name"
    done
}

compose_inside_env() {
    root_dir=$1
    mkdir -p "$root_dir/work/artifacts/compose"
    compose_cmd="/work/DeltaPorts/dportsv3 compose --target $TARGET --delta-root /work/DeltaPorts --freebsd-root /work/freebsd-ports --lock-root /work/DPorts --output /work/artifacts/compose/$TARGET --replace-output --oracle-profile off"
    if [ -n "$ORIGIN" ]; then
        info "running initial full compose for target $TARGET before origin-focused work on $ORIGIN"
    else
        info "running initial full compose for target $TARGET"
    fi
    run_in_chroot "$root_dir" "$compose_cmd"
}

shell_into_env() {
    env_name=$1
    load_state "$env_name"
    [ "$BACKEND" = "chroot" ] || die "unsupported backend in environment: $BACKEND"
    info "preparing shell entry for environment $env_name"
    prepare_root_runtime "$ROOT_DIR"
    info "entering shell for env=$env_name target=$TARGET origin=${ORIGIN:-<full-tree>}"
    info "compose root will be /work/artifacts/compose/$TARGET"
    if run_in_chroot "$ROOT_DIR" 'command -v bash >/dev/null 2>&1'; then
        exec chroot "$ROOT_DIR" /usr/bin/env -i HOME=/root TERM="${TERM:-xterm}" PATH=/usr/local/bin:/usr/local/sbin:/bin:/sbin:/usr/bin:/usr/sbin bash --noprofile --rcfile /root/.dports-dev-env.sh -i
    fi
    exec chroot "$ROOT_DIR" /usr/bin/env -i HOME=/root TERM="${TERM:-xterm}" PATH=/usr/local/bin:/usr/local/sbin:/bin:/sbin:/usr/bin:/usr/sbin ENV=/root/.dports-dev-env.sh /bin/sh -i
}

destroy_env() {
    env_name=$1
    if [ -f "$(state_path "$env_name")" ]; then
        load_state "$env_name"
    elif [ -d "$DPORTS_DEV_ENVS_DIR/$env_name" ]; then
        init_partial_env_state "$env_name"
        warn "environment $env_name has no state file; cleaning partial environment"
    else
        die "environment not found: $env_name"
    fi
    info "destroying environment $env_name"
    if [ -n "$HOST_DISTDIR" ] && [ -d "$HOST_DISTDIR" ]; then
        umount_if_needed "$ROOT_DIR/usr/distfiles"
    fi
    umount_if_needed "$ROOT_DIR/proc"
    umount_if_needed "$ROOT_DIR/dev"
    clear_immutable_flags "$ROOT_DIR"
    rm -rf "$DPORTS_DEV_ENVS_DIR/$env_name"
}

list_envs() {
    if [ ! -d "$DPORTS_DEV_ENVS_DIR" ]; then
        exit 0
    fi
    for state_file in "$DPORTS_DEV_ENVS_DIR"/*/state.env; do
        [ -f "$state_file" ] || continue
        env_name=$(basename "$(dirname "$state_file")")
        # shellcheck disable=SC1090
        . "$state_file"
        printf '%s\t%s\t%s\t%s\n' "$env_name" "$BACKEND" "$TARGET" "$ORIGIN"
    done
}

create_env() {
    require_root
    need_cmd curl
    need_cmd tar
    need_cmd git
    need_cmd chroot
    need_cmd mount_null
    need_cmd mount_procfs

    TARGET=
    ORIGIN=
    SOURCE_DELTA_ROOT=$REPO_ROOT
    DELTAPORTS_BRANCH=$DPORTS_DEV_DELTAPORTS_BRANCH
    BACKEND=chroot
    FREEBSD_BRANCH=
    DPORTS_BRANCH=$DPORTS_DEV_DPORTS_BRANCH
    HOST_DISTDIR=$DPORTS_DEV_HOST_DISTDIR
    ENV_NAME=
    auto_shell=0

    while [ "$#" -gt 0 ]; do
        case "$1" in
            --name)
                [ "$#" -ge 2 ] || die "--name requires a value"
                ENV_NAME=$2
                shift 2
                ;;
            --target)
                [ "$#" -ge 2 ] || die "--target requires a value"
                TARGET=$2
                shift 2
                ;;
            --origin)
                [ "$#" -ge 2 ] || die "--origin requires a value"
                ORIGIN=$2
                shift 2
                ;;
            --delta-root)
                [ "$#" -ge 2 ] || die "--delta-root requires a value"
                SOURCE_DELTA_ROOT=$2
                shift 2
                ;;
            --backend)
                [ "$#" -ge 2 ] || die "--backend requires a value"
                BACKEND=$2
                shift 2
                ;;
            --freebsd-branch)
                [ "$#" -ge 2 ] || die "--freebsd-branch requires a value"
                FREEBSD_BRANCH=$2
                shift 2
                ;;
            --dports-branch)
                [ "$#" -ge 2 ] || die "--dports-branch requires a value"
                DPORTS_BRANCH=$2
                shift 2
                ;;
            --shell)
                auto_shell=1
                shift
                ;;
            --help|-h)
                usage
                exit 0
                ;;
            *)
                die "unknown create option: $1"
                ;;
        esac
    done

    [ -n "$TARGET" ] || die "--target is required"
    [ "$BACKEND" = "chroot" ] || die "unsupported backend: $BACKEND"
    [ -d "$SOURCE_DELTA_ROOT" ] || die "Delta root does not exist: $SOURCE_DELTA_ROOT"
    [ -f "$SOURCE_DELTA_ROOT/dportsv3" ] || die "Delta root does not look like this repo: $SOURCE_DELTA_ROOT"
    git -C "$SOURCE_DELTA_ROOT" rev-parse --git-dir >/dev/null 2>&1 || die "Delta root is not a git checkout: $SOURCE_DELTA_ROOT"

    if [ -z "$FREEBSD_BRANCH" ]; then
        FREEBSD_BRANCH=$(target_to_branch "$TARGET")
    fi
    if [ -z "$ENV_NAME" ]; then
        ENV_NAME=$(default_env_name "$TARGET" "$ORIGIN")
    fi

    env_dir="$DPORTS_DEV_ENVS_DIR/$ENV_NAME"
    ROOT_DIR=$(root_path "$ENV_NAME")
    [ ! -e "$env_dir" ] || die "environment already exists: $ENV_NAME"

    step 1 8 "Resolving latest DragonFly world asset"
    asset=$(fetch_latest_world_asset)

    step 2 8 "Preparing cached DragonFly base root"
    BASE_ARCHIVE=$(ensure_base_archive "$asset")
    BASE_CACHE_KEY=${asset%.tar.gz}
    BASE_EXTRACTED_ROOT=$(ensure_base_extracted "$BASE_CACHE_KEY" "$BASE_ARCHIVE")

    step 3 8 "Refreshing cached repo mirrors"
    DELTAPORTS_MIRROR=$(ensure_local_git_mirror deltaports "$SOURCE_DELTA_ROOT")
    FREEBSD_MIRROR=$(ensure_remote_git_mirror freebsd-ports "$DPORTS_DEV_FREEBSD_PORTS_URL")
    DPORTS_MIRROR=$(ensure_remote_git_mirror DPorts "$DPORTS_DEV_DPORTS_URL")

    step 4 8 "Preparing env source trees"

    step 5 8 "Creating throwaway chroot root"
    copy_base_root "$BASE_EXTRACTED_ROOT" "$ROOT_DIR"

    step 6 8 "Seeding env-local source trees and writing environment state"
    prepare_root_runtime "$ROOT_DIR"
    seed_deltaports_checkout "$DELTAPORTS_MIRROR" "$DELTAPORTS_BRANCH" "$ROOT_DIR/work/DeltaPorts"
    seed_freebsd_checkout "$FREEBSD_MIRROR" "$FREEBSD_BRANCH" "$ROOT_DIR/work/freebsd-ports"
    export_git_tree_from_ref DPorts "$DPORTS_MIRROR" "$DPORTS_BRANCH" "$ROOT_DIR/work/DPorts"
    mkdir -p "$ROOT_DIR/work/artifacts/compose"
    CREATED_AT=$(date -u '+%Y-%m-%dT%H:%M:%SZ')
    write_shell_rc "$ROOT_DIR"
    write_state "$ENV_NAME"

    step 7 8 "Bootstrapping developer tools inside chroot"
    bootstrap_tools "$ROOT_DIR"

    step 8 8 "Running initial compose"
    compose_failed=0
    if ! compose_inside_env "$ROOT_DIR"; then
        compose_failed=1
        warn "compose failed; environment retained for manual investigation"
    fi

    if [ "$auto_shell" -eq 1 ]; then
        if [ "$compose_failed" -eq 1 ]; then
            warn "opening shell despite compose failure because --shell was requested"
        fi
        shell_into_env "$ENV_NAME"
    fi

    if [ "$compose_failed" -eq 1 ]; then
        exit 1
    fi

    info "environment ready: $ENV_NAME"
}

main() {
    ensure_dirs
    action=${1:-}
    case "$action" in
        create)
            shift
            case "${1:-}" in
                --help|-h)
                    usage
                    exit 0
                    ;;
            esac
            create_env "$@"
            ;;
        shell)
            require_root
            case "${2:-}" in
                --help|-h|'')
                    usage
                    exit 0
                    ;;
            esac
            [ "$#" -eq 2 ] || die "shell requires an environment name"
            shell_into_env "$2"
            ;;
        destroy)
            require_root
            case "${2:-}" in
                --help|-h|'')
                    usage
                    exit 0
                    ;;
            esac
            [ "$#" -eq 2 ] || die "destroy requires an environment name"
            destroy_env "$2"
            ;;
        list)
            list_envs
            ;;
        --help|-h|help|'')
            usage
            ;;
        *)
            die "unknown action: $action"
            ;;
    esac
}

main "$@"
