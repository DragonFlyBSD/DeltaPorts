{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "add_file",
  "description": "Add a port-local file (kind=resource, supplies content) or stage a file from the dragonfly source tree (kind=materialize, supplies source path).",
  "type": "object",
  "required": ["type", "dest", "kind"],
  "additionalProperties": false,
  "properties": {
    "type": {"const": "add_file"},
    "dest": {"type": "string", "minLength": 1,
             "description": "Relpath under ports/<origin>/ where the file lands"},
    "kind": {"enum": ["resource", "materialize"]},
    "content": {"type": ["string", "null"],
                "description": "File content. Required iff kind=resource."},
    "source": {"type": ["string", "null"],
               "description": "Source path in the dragonfly tree. Required iff kind=materialize."}
  },
  "allOf": [
    {
      "if": {"properties": {"kind": {"const": "resource"}}},
      "then": {"required": ["content"], "properties": {"content": {"type": "string"}}}
    },
    {
      "if": {"properties": {"kind": {"const": "materialize"}}},
      "then": {"required": ["source"], "properties": {"source": {"type": "string", "minLength": 1}}}
    }
  ]
}
