port www/gitlab-workhorse
type port
reason "auto-converted from Makefile.DragonFly"
target @any

mk add BUILD_DEPENDS "ca_root_nss>=0:security/ca_root_nss"
mk target set dfly-patch <<'MK1'
	${REINPLACE_CMD} -e 's,freebsd,dragonfly,g' \
		${GO_GOPATH}/pkg/mod/github.com/?azure/azure-sdk-for-go/sdk/storage/azblob@v1.0.0/blockblob/mmf_unix.go
MK1
