port www/hs-yesod-bin
type port
reason "auto-converted from Makefile.DragonFly"
target @any

mk target set dfly-patch <<'MK1'
	mv ${WRKSRC}/${PORTNAME}.cabal ${WRKSRC}/${PORTNAME}.cabal.orig
	awk '{print; if (tolower($$1) == "executable") {print "    extra-libraries: m"}}' \
		${WRKSRC}/${PORTNAME}.cabal.orig > ${WRKSRC}/${PORTNAME}.cabal
MK1
mk set IGNORE "unmaintained, please request fixing to users mailing list"
