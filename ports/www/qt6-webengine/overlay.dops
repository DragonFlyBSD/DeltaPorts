port www/qt6-webengine
type port
reason "DragonFly qt6-webengine: libc++ shim, BINARY_ALIAS, CXXFLAGS, LDFLAGS, dfly-patch target"
target @any

mk set USE_CLANG_FALLBACK "default"

mk add BINARY_ALIAS "cpp=${LOCALBASE}/bin/clang-cpp${LLVM_DEFAULT}"
mk add BINARY_ALIAS "cc=${LOCALBASE}/bin/clang${LLVM_DEFAULT}"
mk add BINARY_ALIAS "c++=${LOCALBASE}/bin/clang++${LLVM_DEFAULT}"
mk add BINARY_ALIAS "ar=${LOCALBASE}/bin/llvm-ar${LLVM_DEFAULT}"
mk add BINARY_ALIAS "nm=${LOCALBASE}/bin/llvm-nm${LLVM_DEFAULT}"

mk add CXXFLAGS -nostdlib++
mk add CXXFLAGS -nostdinc++
mk add CXXFLAGS -stdlib=libc++
mk add CXXFLAGS "-I${LOCALBASE}/include"
mk add CXXFLAGS "-I${LOCALBASE}/include/cxxrt"
mk add CXXFLAGS "-cxx-isystem ${LOCALBASE}/llvm${LLVM_DEFAULT}/libcxx/include/c++/v1"
mk add CXXFLAGS -Wno-error=unused-command-line-argument
mk add CXXFLAGS -Wunused-command-line-argument

mk set LDFLAGS "-L /usr/lib -L${LOCALBASE}/llvm${LLVM_DEFAULT}/libcxx/lib/c++ -L /lib"

mk add CONFIGURE_ENV "CXXFLAGS=\"${CXXFLAGS}\" CFLAGS=\"${CFLAGS}\" LDFLAGS=\"${LDFLAGS}\""

mk add LIB_DIRS "${PREFIX}/llvm${LLVM_DEFAULT}/libcxx/lib"

mk add LIB_DEPENDS "libc++.so.1:devel/libcxx${LLVM_DEFAULT}"
mk add LIB_DEPENDS "libgbm.so.1:graphics/mesa-libs"
mk add LIB_DEPENDS "libva.so:multimedia/libva"

mk target set dfly-patch <<'MK'
	# Sandbox stuff
	@${MKDIR} ${WRKSRC}/src/3rdparty/chromium/sandbox/policy/dragonfly
	@${CP} ${WRKSRC}/src/3rdparty/chromium//sandbox/policy/freebsd/sandbox_freebsd.h \
	       ${WRKSRC}/src/3rdparty/chromium/sandbox/policy/dragonfly/sandbox_dragonfly.h
	@${CP} ${WRKSRC}/src/3rdparty/chromium/sandbox/policy/freebsd/sandbox_freebsd.cc \
	       ${WRKSRC}/src/3rdparty/chromium/sandbox/policy/dragonfly/sandbox_dragonfly.cc
	${REINPLACE_CMD} -e "s|FreeBSD|DragonFly|g" \
		-e "s|freebsd\/sandbox_freebsd.h|dragonfly\/sandbox_dragonfly.h|g" \
		${WRKSRC}/src/3rdparty/chromium/sandbox/policy/dragonfly/sandbox_dragonfly.h \
		${WRKSRC}/src/3rdparty/chromium/sandbox/policy/dragonfly/sandbox_dragonfly.cc
	${CP} ${WRKSRC}/src/3rdparty/chromium/base/process/process_handle_freebsd.cc \
		${WRKSRC}/src/3rdparty/chromium/base/process/process_handle_dragonfly.cc
	${CP} ${WRKSRC}/src/3rdparty/chromium/base/process/process_iterator_freebsd.cc \
		${WRKSRC}/src/3rdparty/chromium/base/process/process_iterator_dragonfly.cc
	${CP} ${WRKSRC}/src/3rdparty/chromium/base/process/process_metrics_freebsd.cc \
		${WRKSRC}/src/3rdparty/chromium/base/process/process_metrics_dragonfly.cc
	${CP} ${WRKSRC}/src/3rdparty/chromium/base/system/sys_info_freebsd.cc \
		${WRKSRC}/src/3rdparty/chromium/base/system/sys_info_dragonfly.cc
MK

