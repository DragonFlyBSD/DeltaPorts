port www/firefox
type port
reason "DragonFly-specific firefox build: PULSEAUDIO/LTO filter, MOZ_OPTIONS, CXXFLAGS, BINARY_ALIAS, dfly-patch"
target @any

mk eval OPTIONS_DEFAULT "${OPTIONS_DEFAULT:NPULSEAUDIO}"
mk eval OPTIONS_DEFAULT_x86_64 "${OPTIONS_DEFAULT_x86_64:NLTO}"

mk add MOZ_OPTIONS --disable-webrtc
mk add MOZ_OPTIONS "--with-clang-path=${LOCALBASE}/llvm${LLVM_VERSION}/bin/clang"
mk add MOZ_OPTIONS "--with-libclang-path=${LOCALBASE}/llvm${LLVM_VERSION}/lib"
mk add CXXFLAGS -Wno-multistatement-macros
mk add CXXFLAGS -Wno-class-memaccess

mk set BINARY_ALIAS "clang=${LOCALBASE}/llvm${LLVM_VERSION}/bin/clang clang++=${LOCALBASE}/llvm${LLVM_VERSION}/bin/clang++ wasm-ld=${LOCALBASE}/llvm${LLVM_VERSION}/bin/wasm-ld"

mk target set dfly-patch <<'MK'
	# disable SCTP
	${REINPLACE_CMD} -e 's|MOZ_SCTP|MOZ_DISABLE_SCTP|' \
		${WRKSRC}/netwerk/moz.build
	(cd ${WRKSRC}/gfx/angle/checkout/src/compiler/translator && \
		${REINPLACE_CMD} -e 's|<math.h>|<cmath>|' \
		InfoSink.h IntermNode.cpp)
	${REINPLACE_CMD} -e 's@_XOPEN_SOURCE@&___@g' \
		${WRKSRC}/media/libcubeb/src/cubeb_alsa.c
	${REINPLACE_CMD} -e 's@_POSIX_SOURCE@&___@g' \
		${WRKSRC}/media/libcubeb/src/cubeb_jack.cpp
	${REINPLACE_CMD} -e 's@gtk+-wayland@&z@g' \
		${WRKSRC}/toolkit/moz.configure
MK

file materialize dragonfly/patch-dom_webtransport_api_WebTransportDatagramDuplexStream.cpp -> dragonfly/patch-dom_webtransport_api_WebTransportDatagramDuplexStream.cpp
file materialize dragonfly/patch-image_imgFrame.h -> dragonfly/patch-image_imgFrame.h
file materialize dragonfly/patch-media_libcubeb_src_cubeb__jack.cpp -> dragonfly/patch-media_libcubeb_src_cubeb__jack.cpp
file materialize dragonfly/patch-mozglue_baseprofiler_core_PlatformMacros.h -> dragonfly/patch-mozglue_baseprofiler_core_PlatformMacros.h
file materialize dragonfly/patch-mozglue_baseprofiler_lul_LulElfInt.h -> dragonfly/patch-mozglue_baseprofiler_lul_LulElfInt.h
file materialize dragonfly/patch-third__party_libwebrtc_build_build__config.h -> dragonfly/patch-third__party_libwebrtc_build_build__config.h
file materialize dragonfly/patch-third__party_rust_libc_src_unix_bsd_freebsdlike_dragonfly_mod.rs -> dragonfly/patch-third__party_rust_libc_src_unix_bsd_freebsdlike_dragonfly_mod.rs
file materialize dragonfly/patch-third__party_rust_quinn-udp_src_unix.rs -> dragonfly/patch-third__party_rust_quinn-udp_src_unix.rs
file materialize dragonfly/patch-toolkit_library_gen__buildid.py -> dragonfly/patch-toolkit_library_gen__buildid.py
file materialize dragonfly/patch-toolkit_xre_nsAppRunner.cpp -> dragonfly/patch-toolkit_xre_nsAppRunner.cpp
