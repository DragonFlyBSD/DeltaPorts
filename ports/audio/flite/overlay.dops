port audio/flite
type port
reason "auto-converted from compat (Makefile.DragonFly + dragonfly/)"
target @any

mk target set dfly-patch <<'MK1'
	${REINPLACE_CMD} -e "/-shared -Wl/s/)$$/ -lm)/g"	\
		${WRKSRC}/config/common_make_rules
MK1
file materialize dragonfly/patch-configure -> dragonfly/patch-configure
