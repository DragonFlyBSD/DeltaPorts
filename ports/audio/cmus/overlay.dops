port audio/cmus
type port
reason "auto-converted from compat (Makefile.DragonFly + dragonfly/)"
target @any

mk target set dfly-patch <<'MK1'
	${REINPLACE_CMD} -e 's@\(NCURSES_CFLAGS=\).*@\1""@g'	\
		${WRKSRC}/configure
MK1
file materialize dragonfly/patch-configure -> dragonfly/patch-configure
file materialize dragonfly/patch-scripts_checks.sh -> dragonfly/patch-scripts_checks.sh
