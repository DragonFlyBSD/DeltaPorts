port audio/hts_engine-API
type port
reason "auto-converted from compat (Makefile.DragonFly + dragonfly/)"
target @any

mk set PLIST "${WRKDIR}/fixed-plist"
mk target set dfly-patch <<'MK1'
	${CAT} ${.CURDIR}/pkg-plist | ${SED} -e '/@dir share\/licenses\/hts_engine-API/d' > ${PLIST}
MK1
file materialize dragonfly/patch-lib_HTS__misc.c -> dragonfly/patch-lib_HTS__misc.c
