port games/vamos
type port
reason "auto-converted from Makefile.DragonFly"
target @any

mk set USE_CXXSTD "gnu++98"
mk add CONFIGURE_ENV "CC=c++"
mk target set dfly-patch <<'MK1'
	${REINPLACE_CMD} -e "/LINK) -rpath/s/$$/ -lm/g"	\
		${WRKSRC}/body/Makefile.in	\
		${WRKSRC}/geometry/Makefile.in	\
		${WRKSRC}/media/Makefile.in	\
		${WRKSRC}/track/Makefile.in	\
		${WRKSRC}/world/Makefile.in
MK1
