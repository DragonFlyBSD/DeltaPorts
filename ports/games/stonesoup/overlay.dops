port games/stonesoup
type port
reason "auto-converted from Makefile.DragonFly"
target @any

mk add USES "alias"
mk add CFLAGS "-std=c++11 -DSIGLIBRT=33 # ugly but works"
mk add LDFLAGS "-lexecinfo"
mk target set dfly-patch <<'MK1'
	${REINPLACE_CMD} -e 's@FreeBSD@DragonFly@g' \
		${WRKSRC}/Makefile
MK1
