port science/lammps
type port
reason "auto-converted from Makefile.DragonFly"
target @any

mk add LDFLAGS "-lexecinfo"
mk set LIB_DEPENDS "${LIB_DEPENDS:Nlibhwloc*}"
mk set OPTIONS_DEFAULT "${OPTIONS_DEFAULT:NMPI*}"
mk set CMAKE_ON "${CMAKE_ON:NPKG_MPIIO:NPKG_LATBOLTZ}"
mk target set dfly-install <<'MK1'
	${MKDIR} ${STAGEDIR}${LOCALBASE}/include/lammps/mpi
	${TOUCH} ${STAGEDIR}${LOCALBASE}/include/lammps/mpi/mpi.h
MK1
