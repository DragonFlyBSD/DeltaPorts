port science/tinker
type port
reason "auto-converted from Makefile.DragonFly"
target @any

mk eval BINARY_ALIAS "${BINARY_ALIAS:Ngfortran=*} gfortran=gfortran${_GCC_VER}"
mk target set dfly-patch <<'MK1'
	${REINPLACE_CMD} -e "s@\(-lfftw3_threads\)@-L${LOCALBASE}/lib \1@g" \
		${WRKSRC}/make/Makefile
MK1
