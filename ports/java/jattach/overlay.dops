port java/jattach
type port
reason "auto-converted from compat (Makefile.DragonFly + dragonfly/)"
target @any

mk target set dfly-patch <<'MK1'
	${REINPLACE_CMD} -e 's@FreeBSD@DragonFly@g' \
		${WRKSRC}/Makefile
MK1
file materialize dragonfly/patch-src_posix_psutil.c -> dragonfly/patch-src_posix_psutil.c
