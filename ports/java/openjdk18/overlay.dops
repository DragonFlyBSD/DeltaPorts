port java/openjdk18
type port
reason "DragonFly: build args, configure flags, FreeBSD gcc block guard, upstream patches"
target @any

mk add MAKE_ARGS "CONF_CHECK=ignore"
mk add CONFIGURE_ARGS "--with-stdc++lib=dynamic"

patch apply diffs/Makefile.diff
patch apply diffs/pkg-message.diff

