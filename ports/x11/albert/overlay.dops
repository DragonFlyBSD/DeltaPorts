port x11/albert
type port
reason "auto-converted from Makefile.DragonFly"
target @any

mk add USES "alias"
mk target set dfly-patch <<'MK1'
	${REINPLACE_CMD} -e 's@FreeBSD@DragonFly@g' \
		${WRKSRC}/CMakeLists.txt \
		${WRKSRC}/lib/globalshortcut/CMakeLists.txt
MK1
mk set IGNORE "unmaintained, please request fixing to users mailing list"
