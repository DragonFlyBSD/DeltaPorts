port emulators/bochs
type port
reason "auto-converted from Makefile.DragonFly"
target @any

mk add TERM_USES "ncurses"
mk target set dfly-patch <<'MK1'
	${REINPLACE_CMD} -e 's|__FreeBSD__|__DragonFly__|' \
		${WRKSRC}/iodev/network/eth_socket.cc
	${REINPLACE_CMD} -e 's|__FreeBSD__|__DragonFly__|' \
		${WRKSRC}/iodev/serial.h
MK1
