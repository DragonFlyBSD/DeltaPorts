port net/olsrd
type port
reason "auto-converted from compat (Makefile.DragonFly + dragonfly/)"
target @any

mk add USES "alias"
mk add CFLAGS "-fPIC"
mk target set dfly-patch <<'MK1'
	${REINPLACE_CMD} -e 's@\(freebsd\*\))@\1|dragonfly*)@g'	\
		${WRKSRC}/make/guess_os.sh
MK1
file materialize dragonfly/patch-src_olsr_types.h -> dragonfly/patch-src_olsr_types.h
