port net/xrdp-devel
type port
reason "auto-converted from compat (Makefile.DragonFly + dragonfly/)"
target @any

mk add USES "alias"
mk set RUN_DEPENDS "${RUN_DEPENDS:N*pulseaudio-module-xrdp}"
mk target set dfly-patch <<'MK1'
	${REINPLACE_CMD} -e 's@\(\*freebsd\*\))@\1|*dragonfly*)@g' \
		${WRKSRC}/configure.ac
MK1
file materialize dragonfly/patch-librfxcodec_m4_nasm.m4 -> dragonfly/patch-librfxcodec_m4_nasm.m4
