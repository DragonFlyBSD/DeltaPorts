port net/istgt
type port
reason "auto-converted from Makefile.DragonFly"
target @any

mk add USES "ssl"
mk add CFLAGS "-I${OPENSSLINC}"
mk add LDFLAGS "-L${OPENSSLLIB}"
mk add CONFIGURE_ARGS "ac_cv_lib_md_MD5Update=no"
mk target set dfly-patch <<'MK1'
	${REINPLACE_CMD} -e 's@<cam/@<bus/cam/@g' \
		${WRKSRC}/src/istgt_lu_pass.c
MK1
