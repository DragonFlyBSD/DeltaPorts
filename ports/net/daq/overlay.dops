port net/daq
type port
reason "disable netmap module, remove netmap plist entry, materialize dragonfly patch"
target @any

mk add CONFIGURE_ARGS --disable-netmap-module
patch apply diffs/pkg-plist.diff
file materialize dragonfly/patch-os-daq-modules_daq__dump.c -> dragonfly/patch-os-daq-modules_daq__dump.c
