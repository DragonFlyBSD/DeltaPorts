port net/3proxy
type port
reason "auto-converted from compat (Makefile.DragonFly + dragonfly/)"
target @any

mk target set dfly-patch <<'MK1'
	${REINPLACE_CMD} -e 's@LN \?=@LN =@g' ${WRKSRC}/Makefile.FreeBSD
MK1
file materialize dragonfly/patch-src_proxymain.c -> dragonfly/patch-src_proxymain.c
file materialize dragonfly/patch-src_structures.h -> dragonfly/patch-src_structures.h
