port net/dhcprelya
type port
reason "auto-converted from Makefile.DragonFly"
target @any

mk add USES "localbase:ldflags"
mk add LIB_DEPENDS "libradius.so.4:net/libradius"
mk add CFLAGS "-DSLIST_FOREACH_SAFE=SLIST_FOREACH_MUTABLE"
mk target set dfly-patch <<'MK1'
	${REINPLACE_CMD} -e 's@-lthr@-pthread@g'	\
		${WRKSRC}/Makefile
	${REINPLACE_CMD} -e '/sys\/mac\.h/d'	\
		${WRKSRC}/dhcprelya.h	\
		${WRKSRC}/net_utils.c
MK1
