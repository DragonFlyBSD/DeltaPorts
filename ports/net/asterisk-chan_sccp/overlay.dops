port net/asterisk-chan_sccp
type port
reason "add MAKE_ENV PBX_DATADIR and dfly-patch for asterisk13 flavor"
target @any

mk block set condition "defined(FLAVOR) && ${FLAVOR:Masterisk13}" <<'MK'
MAKE_ENV+=	PBX_DATADIR=${LOCALBASE}/share/asterisk
MK
mk target set dfly-patch <<'MK'
.if defined(FLAVOR) && ${FLAVOR:Masterisk13}
	${REINPLACE_CMD} -e "s@PBX_DATADIR=\"@&${LOCALBASE}/share/asterisk\" #@g" \
		${WRKSRC}/autoconf/acinclude.m4
.endif
MK
