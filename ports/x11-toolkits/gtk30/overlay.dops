port x11-toolkits/gtk30
type port
reason "disable COLORD option to avoid polkit->spidermonkey->llvm dependency chain"
target @any

mk eval OPTIONS_DEFAULT "${OPTIONS_DEFAULT:NCOLORD}"

file materialize dragonfly/patch-gdk_wayland_gdkdevice-wayland.c -> dragonfly/patch-gdk_wayland_gdkdevice-wayland.c
