port textproc/fcitx5
type port
reason "auto-converted from compat (Makefile.DragonFly + dragonfly/)"
target @any

mk set USE_CLANG_FALLBACK "default"
mk target set dfly-patch <<'MK1'
	${REINPLACE_CMD} -e 's@ MATCHES "\(BSD\)"@ MATCHES "\1|DragonFly"@g' \
		${WRKSRC}/CMakeLists.txt
MK1
file materialize dragonfly/patch-src_lib_fcitx-utils_misc.cpp -> dragonfly/patch-src_lib_fcitx-utils_misc.cpp
file materialize dragonfly/patch-src_lib_fcitx-utils_semver.h -> dragonfly/patch-src_lib_fcitx-utils_semver.h
