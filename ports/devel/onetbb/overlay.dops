port devel/onetbb
type port
reason "auto-converted from compat (Makefile.DragonFly + dragonfly/)"
target @any

mk set LIB_DEPENDS "${LIB_DEPENDS:Nlibhwloc*}"
mk set DFLY_PLIST "${WRKSRC}/pkg-plist"
mk set PLIST "${DFLY_PLIST}"
mk target set dfly-patch <<'MK1'
	${CP} -v ${.CURDIR:H}/onetbb/pkg-plist ${DFLY_PLIST}
	${REINPLACE_CMD} -e '/libtbbbind/d' ${DFLY_PLIST}
MK1
file materialize dragonfly/patch-CMakeLists.txt -> dragonfly/patch-CMakeLists.txt
file materialize dragonfly/patch-examples_parallel__for_tachyon_src_types.hpp -> dragonfly/patch-examples_parallel__for_tachyon_src_types.hpp
