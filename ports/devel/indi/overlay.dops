port devel/indi
type port
reason "auto-converted from Makefile.DragonFly"
target @any

mk set USES "${USES:Nninja} gmake alias"
mk target set dfly-patch <<'MK1'
	${REINPLACE_CMD} -e 's@FreeBSD@DragonFly@g' \
		${WRKSRC}/cmake_modules/CMakeCommon.cmake \
		${WRKSRC}/cmake_modules/FindIconv.cmake \
		${WRKSRC}/CMakeLists.txt
MK1
