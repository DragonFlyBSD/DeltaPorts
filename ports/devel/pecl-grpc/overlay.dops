port devel/pecl-grpc
type port
reason "auto-converted from compat (Makefile.DragonFly + dragonfly/)"
target @any

mk target set dfly-patch <<'MK1'
	${REINPLACE_CMD} -e 's|FreeBSD|DragonFly|' \
		${WRKSRC}/third_party/abseil-cpp/absl/base/config.h \
		${WRKSRC}/third_party/abseil-cpp/absl/base/internal/endian.h \
		${WRKSRC}/third_party/abseil-cpp/absl/base/internal/sysinfo.cc \
		${WRKSRC}/third_party/abseil-cpp/absl/base/internal/raw_logging.cc
MK1
mk set DFLY_UNMAINTAINED "yes"
file materialize dragonfly/patch-include_grpc_event__engine_port.h -> dragonfly/patch-include_grpc_event__engine_port.h
file materialize dragonfly/patch-include_grpc_support_port__platform.h -> dragonfly/patch-include_grpc_support_port__platform.h
file materialize dragonfly/patch-src_core_lib_gpr_posix_time.cc -> dragonfly/patch-src_core_lib_gpr_posix_time.cc
file materialize dragonfly/patch-src_core_lib_iomgr_port.h -> dragonfly/patch-src_core_lib_iomgr_port.h
file materialize dragonfly/patch-third__party_abseil-cpp_absl_debugging_internal_vdso__support.cc -> dragonfly/patch-third__party_abseil-cpp_absl_debugging_internal_vdso__support.cc
file materialize dragonfly/patch-third__party_abseil-cpp_absl_status_status.cc -> dragonfly/patch-third__party_abseil-cpp_absl_status_status.cc
