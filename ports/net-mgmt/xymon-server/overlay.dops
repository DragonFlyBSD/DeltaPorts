port net-mgmt/xymon-server
type port
reason "auto-converted from compat (Makefile.DragonFly + dragonfly/)"
target @any

mk target set dfly-patch <<'MK1'
	${REINPLACE_CMD} -e 's@-D_REENTRANT @&-Wno-stringop-truncation @g' \
		${WRKSRC}/build/Makefile.FreeBSD
MK1
file materialize dragonfly/patch-lib_sendmsg.c -> dragonfly/patch-lib_sendmsg.c
