port lang/v8
type port
reason "auto-converted from compat (Makefile.DragonFly + dragonfly/)"
target @any

mk eval BUILD_DEPENDS "${BUILD_DEPENDS:N*binutils}"
mk add GN_ARGS "v8_enable_i18n_support=false"
mk add GN_ARGS "use_lld=false is_clang=false"
file materialize dragonfly/patch-build_build__config.h -> dragonfly/patch-build_build__config.h
file materialize dragonfly/patch-build_config_gcc_BUILD.gn -> dragonfly/patch-build_config_gcc_BUILD.gn
file materialize dragonfly/patch-include_v8config.h -> dragonfly/patch-include_v8config.h
file materialize dragonfly/patch-src_base_platform_platform-freebsd.cc -> dragonfly/patch-src_base_platform_platform-freebsd.cc
file materialize dragonfly/patch-third__party_icu_source_common_unicode_platform.h -> dragonfly/patch-third__party_icu_source_common_unicode_platform.h
file materialize dragonfly/patch-third__party_zlib_contrib_minizip_ioapi.h -> dragonfly/patch-third__party_zlib_contrib_minizip_ioapi.h
file materialize dragonfly/patch-tools_testrunner_local_utils.py -> dragonfly/patch-tools_testrunner_local_utils.py
