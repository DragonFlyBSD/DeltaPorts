port lang/mosh
type port
reason "auto-converted from Makefile.DragonFly"
target @any

mk add USES "alias"
mk target set dfly-patch <<'MK1'
	${REINPLACE_CMD} -e 's@\(\*freebsd\*\))@\1|*dragonfly*)@g' \
			 -e 's@^freebsd\*@&|dragonfly*@g' \
			 -e 's@\(ptracestub_common\)=true@\1=false@g' \
			 -e 's@HAVE_PTRACE_COMMON@&___@g' \
		${WRKSRC}/configure
MK1
