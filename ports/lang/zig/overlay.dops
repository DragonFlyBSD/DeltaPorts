port lang/zig
type port
reason "auto-converted from Makefile.DragonFly"
target @any

mk eval STATIC_LDFLAGS "${STATIC_LDFLAGS:N-lmd} -llzma"
mk target set dfly-patch <<'MK1'
	${MKDIR} ${BUILD_WRKSRC}
		${TOUCH} ${BUILD_WRKSRC}/build.ninja
	${REINPLACE_CMD} -e 's@LLVM_SYSTEM_LIBS_SPACES}"@LLVM_SYSTEM_LIBS_SPACES} -llzma"@g' \
		${WRKSRC}/cmake/Findllvm.cmake

MK1
