port lang/cling
type port
reason "DragonFly: mark broken on LLVM 5.0.0, materialize cmake patch"
target @any

mk block set condition "${LLVM_RELEASE:M5.0.0}" <<'MK'
BROKEN= pending update
MK

file materialize dragonfly/patch-cmake_modules_HandleLLVMOptions.cmake -> dragonfly/patch-cmake_modules_HandleLLVMOptions.cmake
