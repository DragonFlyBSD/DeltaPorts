port deskutils/terminal-image-viewer
type port
reason "auto-converted from Makefile.DragonFly"
target @any

mk set USE_GCC_VERSION "${GCC_DEFAULT}"
mk add LDFLAGS "-lstdc++fs"
mk target set dfly-patch <<'MK1'
	${REINPLACE_CMD} -e 's@<experimental/filesystem>@<filesystem>@g' \
			 -e 's@experimental::filesystem@filesystem@g' \
		${WRKSRC}/tiv.cpp
MK1
