port deskutils/kdeconnect-kde
type port
reason "auto-converted from Makefile.DragonFly"
target @any

mk eval LIB_DEPENDS "${LIB_DEPENDS:NlibKF5PulseAudioQt*}"
mk set DFLY_PLIST "${WRKSRC}/pkg-plist"
mk set PLIST "${DFLY_PLIST}"
mk target set dfly-patch <<'MK1'
	${CP} -v ${.CURDIR:H}/kdeconnect-kde/pkg-plist ${DFLY_PLIST}
	${REINPLACE_CMD} -e '/findthisdevice/d' -e '/pausemusic/d' -e '/_systemvolume/d' ${DFLY_PLIST}
MK1
