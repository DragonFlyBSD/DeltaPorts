port net-im/tg_owt
type port
reason "auto-converted from compat (Makefile.DragonFly + dragonfly/)"
target @any

mk set USE_GCC_VERSION "${GCC_DEFAULT}"
mk add USES "xorg"
mk add USE_XORG "x11 xtst"
mk set BUILD_DEPENDS "${BUILD_DEPENDS:Npulseaudio*}"
mk target set dfly-patch <<'MK1'
	${REINPLACE_CMD} -e '/pulse/d' \
		-e '/WEBRTC_ENABLE_LINUX_PULSE/d' \
		${WRKSRC}/cmake/libwebrtcbuild.cmake \
		${WRKSRC}/CMakeLists.txt
MK1
file materialize dragonfly/patch-cmake_libwebrtcbuild.cmake -> dragonfly/patch-cmake_libwebrtcbuild.cmake
file materialize dragonfly/patch-src_rtc__base_byte__order.h -> dragonfly/patch-src_rtc__base_byte__order.h
file materialize dragonfly/patch-src_rtc__base_ifaddrs__converter.h -> dragonfly/patch-src_rtc__base_ifaddrs__converter.h
file materialize dragonfly/patch-src_rtc__base_platform__thread__types.cc -> dragonfly/patch-src_rtc__base_platform__thread__types.cc
file materialize dragonfly/patch-src_system__wrappers_source_cpu__info.cc -> dragonfly/patch-src_system__wrappers_source_cpu__info.cc
