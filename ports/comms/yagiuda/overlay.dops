port comms/yagiuda
type port
reason "auto-converted from compat (Makefile.DragonFly + dragonfly/)"
target @any

mk target set dfly-patch <<'MK1'
	${REINPLACE_CMD} -e 's@extern int errno;@#include <errno.h>@g'	\
		${WRKSRC}/src/*.c
MK1
file materialize dragonfly/pacth-src_globals.h -> dragonfly/pacth-src_globals.h
