port comms/cubicsdr
type port
reason "auto-converted from Makefile.DragonFly"
target @any

mk add USES "alias"
mk add CMAKE_ARGS "-DUSE_AUDIO_PULSE:BOOL=OFF -DUSE_AUDIO_ALSA:BOOL=ON"
mk set LIB_DEPENDS "${LIB_DEPENDS:Nlibpulse*}"
mk add LIB_DEPENDS "libasound.so:audio/alsa-lib"
mk add RUN_DEPENDS "${LOCALBASE}/lib/alsa-lib/libasound_module_pcm_oss.so:audio/alsa-plugins"
mk add RUN_DEPENDS "alsa-lib>=1.1.1_1:audio/alsa-lib"
