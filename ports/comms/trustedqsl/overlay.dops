port comms/trustedqsl
type port
reason "auto-converted from Makefile.DragonFly"
target @any

mk target set dfly-patch <<'MK1'
	${REINPLACE_CMD} -e 's@ STREQUAL "\(FreeBSD\)"@ MATCHES "\1|DragonFly"@g'	\
		${WRKSRC}/apps/CMakeLists.txt				\
		${WRKSRC}/cmakemodules/FindBDB.cmake
MK1
mk set DFLY_UNMAINTAINED "yes"
