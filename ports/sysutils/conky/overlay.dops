port sysutils/conky
type port
reason "auto-converted from compat (Makefile.DragonFly + dragonfly/)"
target @any

mk set MAKE_JOBS_UNSAFE "yes"
mk add USES "gmake"
file materialize dragonfly/patch-cmake_ConkyPlatformChecks.cmake -> dragonfly/patch-cmake_ConkyPlatformChecks.cmake
file materialize dragonfly/patch-src_CMakeLists.txt -> dragonfly/patch-src_CMakeLists.txt
file materialize dragonfly/patch-src_common.cc -> dragonfly/patch-src_common.cc
