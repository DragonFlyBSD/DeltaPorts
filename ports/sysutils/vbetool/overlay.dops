port sysutils/vbetool
type port
reason "auto-converted from Makefile.DragonFly"
target @any

mk target set dfly-patch <<'MK1'
	${REINPLACE_CMD} -e 's@ifndef \(__FreeBSD__\)@if \!defined(\1) \&\& \!defined(__DragonFly__)@g'	\
			 -e 's@ifdef \(__FreeBSD__\)@if defined(\1) || defined(__DragonFly__)@g'	\
		${WRKSRC}/vbetool.c
MK1
