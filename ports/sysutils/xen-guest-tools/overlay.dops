port sysutils/xen-guest-tools
type port
reason "auto-converted from Makefile.DragonFly"
target @any

mk set BROKEN "requires kernel support"
mk set MAKE_ENV "${MAKE_ENV:Nclang=y:NFREEBSD_PORT=y}"
mk add USES "ncurses"
mk target set dfly-patch <<'MK1'
	${CP} ${WRKSRC}/config/FreeBSD.mk \
		${WRKSRC}/config/DragonFly.mk
MK1
