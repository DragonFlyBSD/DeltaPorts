port sysutils/libcdio
type port
reason "auto-converted from Makefile.DragonFly"
target @any

mk add CONFIGURE_ENV "am_cv_func_iconv_works=yes"
mk target set dfly-patch <<'MK1'
	${REINPLACE_CMD} -e 's@<cam/@<bus/cam/@g' \
			 -e 's@__FreeBSD_version@900001@g' \
			 -e 's@__FreeBSD_kernel_version@900001@g' \
		${WRKSRC}/lib/driver/FreeBSD/freebsd.h
MK1
