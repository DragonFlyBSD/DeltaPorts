port sysutils/password-store
type port
reason "auto-converted from Makefile.DragonFly"
target @any

mk add RUN_DEPENDS "base64:converters/base64"
mk target set dfly-patch <<'MK1'
	${REINPLACE_CMD} -E \
		-e 's|GETOPT="getopt"|GETOPT="${LOCALBASE}/bin/getopt"|' \
		-e 's|SHRED="shred -f -z"|SHRED="rm -P -f"|' \
		${WRKSRC}/src/password-store.sh
MK1
