port sysutils/gkrellm2
type port
reason "auto-converted from compat (Makefile.DragonFly + dragonfly/)"
target @any

mk add LDFLAGS "-lkvm -lkinfo"
mk target set dfly-patch <<'MK1'
	${REINPLACE_CMD} -e 's@-lmd[[:>:]]@@g' ${WRKSRC}/Makefile \
		${WRKSRC}/server/Makefile ${WRKSRC}/src/Makefile
MK1
file materialize dragonfly/patch-src_sysdeps_dragonfly.c -> dragonfly/patch-src_sysdeps_dragonfly.c
