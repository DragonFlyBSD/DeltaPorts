port sysutils/mptd
type port
reason "auto-converted from compat (Makefile.DragonFly + dragonfly/)"
target @any

mk target set dfly-patch <<'MK1'
	${REINPLACE_CMD} -e 's@dev/mpt/@dev/disk/mpt/@g'	\
		${WRKSRC}/mptd.h
	${REINPLACE_CMD} -e 's@<cam/@<bus/cam/@g' \
		${WRKSRC}/mpt_cam.c
MK1
file materialize dragonfly/patch-mptd.h -> dragonfly/patch-mptd.h
