port misc/dartsim
type port
reason "auto-converted from compat (Makefile.DragonFly + dragonfly/)"
target @any

mk set LIB_DEPENDS "${LIB_DEPENDS:Nlibtbb*}"
mk set IGNORE "unmaintained, please request fixing to users mailing list"
file materialize dragonfly/patch-dart_common_Platform.hpp -> dragonfly/patch-dart_common_Platform.hpp
file materialize dragonfly/patch-dart_external_odelcpsolver_matrix.cpp -> dragonfly/patch-dart_external_odelcpsolver_matrix.cpp
file materialize dragonfly/patch-dart_gui_LoadOpengl.hpp -> dragonfly/patch-dart_gui_LoadOpengl.hpp
file materialize dragonfly/patch-dart_gui_glut_LoadGlut.hpp -> dragonfly/patch-dart_gui_glut_LoadGlut.hpp
