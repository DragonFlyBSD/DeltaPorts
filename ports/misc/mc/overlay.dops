port misc/mc
type port
reason "auto-converted from Makefile.DragonFly"
target @any

mk add NCURSES_USES "ncurses"
mk add BUILD_DEPENDS "gsed:textproc/gsed"
mk target set dfly-patch <<'MK1'
	${REINPLACE_CMD} -e 's@[[:<:]]sed[[:>:]]@gsed@g' \
		${WRKSRC}/doc/man/hu/Makefile.in
	${REINPLACE_CMD} -e 's@-ltermcap@-lncurses@g' \
		${WRKSRC}/configure
MK1
