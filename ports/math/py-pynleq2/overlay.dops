port math/py-pynleq2
type port
reason "auto-converted from Makefile.DragonFly"
target @any

mk add BUILD_DEPENDS "libstdthreads>0:misc/libstdthreads"
mk eval USES "${USES:N*flang} fortran"
mk set BINARY_ALIAS "flang=gfortran8"
mk add LDFLAGS "-Wl,-rpath=/usr/local/lib/gcc8 -L/usr/local/lib/gcc8"
mk target set dfly-patch <<'MK1'
	${REINPLACE_CMD} -e "s@flang@gfortran@g" \
		${WRKSRC}/setup.py
MK1
mk set DFLY_UNMAINTAINED "yes"
