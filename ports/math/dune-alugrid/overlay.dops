port math/dune-alugrid
type port
reason "auto-converted from Makefile.DragonFly"
target @any

mk add CMAKE_ARGS "-DDUNE_CV_PTHREAD_TLS_COMPILES:bool=TRUE"
mk target set zdfly-patch <<'MK1'
	${REINPLACE_CMD} -e 's@"include <pthread.h>@"#include <pthread.h>@g' \
			 -e '/CMAKE_CXX_FLAGS/s@-DUSE_PTHREADS=1"@-pthread &@g' \
			 -e 's@#message@message@g' \
		${WRKSRC}/cmake/modules/FindPThreads.cmake
MK1
