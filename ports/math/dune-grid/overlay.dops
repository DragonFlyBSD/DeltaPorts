port math/dune-grid
type port
reason "auto-converted from Makefile.DragonFly"
target @any

mk add CMAKE_ARGS "-DMPI_C_COMPILER=\"${LOCALBASE}/mpi/openmpi/bin/mpicc\""
mk add CMAKE_ARGS "-DMPI_CXX_COMPILER=\"${LOCALBASE}/mpi/openmpi/bin/mpicxx\""
mk add CMAKE_ARGS "-DMPI_Fortran_COMPILER=\"${LOCALBASE}/mpi/openmpi/bin/mpifort\""
