port graphics/cegui
type port
reason "auto-converted from compat (Makefile.DragonFly + dragonfly/)"
target @any

mk add USES "alias"
mk add CXXFLAGS "-I${LOCALBASE}/include"
mk target set dfly-patch <<'MK1'
	${REINPLACE_CMD} -e 's@"\(FreeBSD\)"@"\1|DragonFly"@g'		\
		${WRKSRC}/cegui/src/CMakeLists.txt
MK1
file materialize dragonfly/patch-cegui_src_System.cpp -> dragonfly/patch-cegui_src_System.cpp
