port graphics/inkscape
type port
reason "auto-converted from compat (Makefile.DragonFly + dragonfly/)"
target @any

mk set USE_GCC_VERSION "${GCC_DEFAULT}"
mk add USES "gmake"
mk add LDFLAGS "\"-Wl,-z,origin\""
file materialize dragonfly/patch-src_path-prefix.cpp -> dragonfly/patch-src_path-prefix.cpp
