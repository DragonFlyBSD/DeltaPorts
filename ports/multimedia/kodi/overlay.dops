port multimedia/kodi
type port
reason "add gmake USES, CXXFLAGS, PLIST_SUB OPSYS, strip GBM/WAYLAND/SSE4 options, dfly-patch cp/reinplace, apply plist, materialize dragonfly patches"
target @any

mk add USES gmake
mk add CXXFLAGS -Wno-double-promotion
mk add PLIST_SUB "OPSYS=${OPSYS:tl}"
mk eval OPTIONS_DEFAULT "${OPTIONS_DEFAULT:NGBM:NWAYLAND}"
mk eval OPTIONS_DEFAULT_x86_64 "${OPTIONS_DEFAULT_x86_64:NSSE4_1:NSSE4_2}"
mk target set dfly-patch <<'MK'
	${CP} -v ${WRKSRC}/system/settings/freebsd.xml ${WRKSRC}/system/settings/dragonfly.xml
	${CP} -Rv ${WRKSRC}/cmake/scripts/freebsd  ${WRKSRC}/cmake/scripts/dragonfly
	${REINPLACE_CMD} -e 's@FREEBSD@DRAGONFLY@g' -e 's@freebsd@dragonfly@g' -e 's@amd64@x86_64@g' \
		${WRKSRC}/cmake/scripts/dragonfly/ArchSetup.cmake
	${CP} -Rv ${WRKSRC}/cmake/platform/freebsd ${WRKSRC}/cmake/platform/dragonfly
	${REINPLACE_CMD} -e 's@FREEBSD@DRAGONFLY@g' \
		${WRKSRC}/cmake/platform/dragonfly/defines.txt
	${CP} -Rv ${WRKSRC}/cmake/treedata/freebsd ${WRKSRC}/cmake/treedata/dragonfly
	${REINPLACE_CMD} -e 's@freebsd@dragonfly@g' \
		${WRKSRC}/cmake/treedata/dragonfly/subdirs.txt
	${CP} -Rv ${WRKSRC}/xbmc/platform/freebsd  ${WRKSRC}/xbmc/platform/dragonfly
	${REINPLACE_CMD} -e 's@freebsd@dragonfly@' \
		${WRKSRC}/xbmc/platform/dragonfly/CMakeLists.txt
	${CP} -Rv ${WRKSRC}/tools/buildsteps/freebsd \
		  ${WRKSRC}/tools/buildsteps/dragonfly
	${REINPLACE_CMD} -e 's@freebsd@dragonfly@g' \
		${WRKSRC}/tools/buildsteps/dragonfly/*
	${REINPLACE_CMD} -e 's@defined (TARGET_FREEBSD)@defined(TARGET_FREEBSD)@g' \
			 -e 's@defined(TARGET_FREEBSD)@(&||defined(TARGET_DRAGONFLY))@g' \
		${WRKSRC}/xbmc/platform/posix/network/NetworkPosix.cpp
	${REINPLACE_CMD} -e 's@defined(TARGET_FREEBSD)@(&||defined(TARGET_DRAGONFLY))@g' \
			 -e 's@#ifdef \(TARGET_FREEBSD\)@#if defined(TARGET_FREEBSD) || defined(TARGET_DRAGONFLY)@g' \
		${WRKSRC}/xbmc/platform/linux/peripherals/PeripheralBusUSBLibUSB.cpp
	${REINPLACE_CMD} -e 's@defined(TARGET_FREEBSD)@(&||defined(TARGET_DRAGONFLY))@g' \
		${WRKSRC}/tools/depends/native/TexturePacker/src/XBTFWriter.cpp \
		${WRKSRC}/xbmc/LangInfo.cpp \
		${WRKSRC}/xbmc/Util.cpp \
		${WRKSRC}/xbmc/addons/kodi-dev-kit/include/kodi/Filesystem.h \
		${WRKSRC}/xbmc/addons/kodi-dev-kit/include/kodi/gui/gl/GL.h \
		${WRKSRC}/xbmc/cores/AudioEngine/Sinks/AESinkOSS.cpp \
		${WRKSRC}/xbmc/cores/DllLoader/exports/emu_msvcrt.cpp \
		${WRKSRC}/xbmc/cores/DllLoader/exports/emu_msvcrt.h \
		${WRKSRC}/xbmc/cores/DllLoader/exports/util/EmuFileWrapper.h \
		${WRKSRC}/xbmc/cores/DllLoader/exports/wrapper.c \
		${WRKSRC}/xbmc/guilib/XBTFReader.cpp \
		${WRKSRC}/xbmc/guilib/guiinfo/SystemGUIInfo.cpp \
		${WRKSRC}/xbmc/interfaces/python/XBPython.cpp \
		${WRKSRC}/xbmc/peripherals/bus/PeripheralBusUSB.h \
		${WRKSRC}/xbmc/platform/posix/Filesystem.cpp \
		${WRKSRC}/xbmc/platform/posix/PlatformDefs.h \
		${WRKSRC}/xbmc/platform/posix/PosixMountProvider.cpp \
		${WRKSRC}/xbmc/platform/posix/main.cpp \
		${WRKSRC}/xbmc/storage/DetectDVDType.cpp \
		${WRKSRC}/xbmc/storage/MediaManager.cpp \
		${WRKSRC}/xbmc/system_gl.h \
		${WRKSRC}/xbmc/utils/CharsetConverter.cpp \
		${WRKSRC}/xbmc/utils/test/TestCPUInfo.cpp \
		${WRKSRC}/xbmc/windowing/X11/XRandR.cpp
MK
mk set MAKE_JOBS_UNSAFE "yes"
patch apply diffs/pkg-plist.diff
file materialize dragonfly/patch-addons_xbmc.addon_metadata.xsd -> dragonfly/patch-addons_xbmc.addon_metadata.xsd
file materialize dragonfly/patch-cmake_modules_buildtools_FindTexturePacker.cmake -> dragonfly/patch-cmake_modules_buildtools_FindTexturePacker.cmake
file materialize dragonfly/patch-cmake_scripts_common_AddonHelpers.cmake -> dragonfly/patch-cmake_scripts_common_AddonHelpers.cmake
file materialize dragonfly/patch-cmake_scripts_common_ArchSetup.cmake -> dragonfly/patch-cmake_scripts_common_ArchSetup.cmake
file materialize dragonfly/patch-cmake_scripts_common_Platform.cmake -> dragonfly/patch-cmake_scripts_common_Platform.cmake
file materialize dragonfly/patch-lib_libUPnP_CMakeLists.txt -> dragonfly/patch-lib_libUPnP_CMakeLists.txt
file materialize dragonfly/patch-lib_libUPnP_patches_0002-platinum-add-custom-CMakeLists.txt.patch -> dragonfly/patch-lib_libUPnP_patches_0002-platinum-add-custom-CMakeLists.txt.patch
file materialize dragonfly/patch-tools_depends_m4_xbmc__arch.m4 -> dragonfly/patch-tools_depends_m4_xbmc__arch.m4
file materialize dragonfly/patch-tools_depends_target_ffmpeg_CMakeLists.txt -> dragonfly/patch-tools_depends_target_ffmpeg_CMakeLists.txt
file materialize dragonfly/patch-xbmc_addons_addoninfo_AddonInfoBuilder.cpp -> dragonfly/patch-xbmc_addons_addoninfo_AddonInfoBuilder.cpp
file materialize dragonfly/patch-xbmc_cores_AudioEngine_CMakeLists.txt -> dragonfly/patch-xbmc_cores_AudioEngine_CMakeLists.txt
file materialize dragonfly/patch-xbmc_network_DNSNameCache.cpp -> dragonfly/patch-xbmc_network_DNSNameCache.cpp
file materialize dragonfly/patch-xbmc_platform_freebsd_network_NetworkFreebsd.h -> dragonfly/patch-xbmc_platform_freebsd_network_NetworkFreebsd.h
file materialize dragonfly/patch-xbmc_platform_posix_PosixTimezone.cpp -> dragonfly/patch-xbmc_platform_posix_PosixTimezone.cpp
file materialize dragonfly/patch-xbmc_settings_Settings.cpp -> dragonfly/patch-xbmc_settings_Settings.cpp
file materialize dragonfly/patch-xbmc_utils_SystemInfo.cpp -> dragonfly/patch-xbmc_utils_SystemInfo.cpp
