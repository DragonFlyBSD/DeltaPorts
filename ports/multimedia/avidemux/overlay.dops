port multimedia/avidemux
type port
reason "auto-converted from compat (Makefile.DragonFly + dragonfly/)"
target @any

mk add USES "alias"
mk set OPTIONS_DEFAULT "${OPTIONS_DEFAULT:NPULSEAUDIO}"
mk add CXXFLAGS "-fpermissive"
mk target set dfly-patch <<'MK1'
	${ECHO_MSG} 'target_link_libraries(ADM_core6 "-lexecinfo")' >> \
		${WRKSRC}/avidemux_core/ADM_core/src/CMakeLists.txt
MK1
file materialize dragonfly/patch-avidemux_core__ADM_core__include__ADM_default.h -> dragonfly/patch-avidemux_core__ADM_core__include__ADM_default.h
