port multimedia/libopenshot
type port
reason "auto-converted from compat (Makefile.DragonFly + dragonfly/)"
target @any

mk add USES "alias"
mk add OPTIONS_EXCLUDE "DOCS"
mk add CMAKE_BOOL_OFF "CMAKE_DISABLE_FIND_PACKAGE_Doxygen ENABLE_DOCS"
mk target set dfly-patch <<'MK1'
	${REINPLACE_CMD} -e 's@FreeBSD@DragonFly@g' \
		${WRKSRC}/src/CMakeLists.txt
MK1
file materialize dragonfly/patch-src_MagickUtilities.h -> dragonfly/patch-src_MagickUtilities.h
