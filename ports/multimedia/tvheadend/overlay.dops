port multimedia/tvheadend
type port
reason "auto-converted from compat (Makefile.DragonFly + dragonfly/)"
target @any

mk target set dfly-patch <<'MK1'
	${REINPLACE_CMD} -e '/uname/s@PLATFORM=@&freebsd #@g' \
		${WRKSRC}/support/configure.inc
	${REINPLACE_CMD} -e 's@struct uuid@&___@g' \
		${WRKSRC}/src/uuid.h
MK1
file materialize dragonfly/patch-src_udp.c -> dragonfly/patch-src_udp.c
file materialize dragonfly/patch-sys_socket.h -> dragonfly/patch-sys_socket.h
