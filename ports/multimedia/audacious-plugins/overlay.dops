port multimedia/audacious-plugins
type port
reason "strip PULSEAUDIO from OPTIONS_DEFAULT, materialize dragonfly patches"
target @any

mk eval OPTIONS_DEFAULT "${OPTIONS_DEFAULT:NPULSEAUDIO}"
file materialize dragonfly/patch-src_gio_gio.cc -> dragonfly/patch-src_gio_gio.cc
file materialize dragonfly/patch-src_neon_neon.cc -> dragonfly/patch-src_neon_neon.cc
