port multimedia/xawtv
type port
reason "auto-converted from compat (Makefile.DragonFly + dragonfly/)"
target @any

mk add USES "alias"
mk target set dfly-patch <<'MK1'
	${REINPLACE_CMD} -e 's@\(OpenBSD | FreeBSD | NetBSD\))@\1 | DragonFly)@g'	\
		${WRKSRC}/configure
MK1
file materialize dragonfly/patch-console_ftp.c -> dragonfly/patch-console_ftp.c
