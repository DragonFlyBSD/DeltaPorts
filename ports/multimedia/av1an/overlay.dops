port multimedia/av1an
type port
reason "auto-converted from Makefile.DragonFly"
target @any

mk target set dfly-patch <<'MK1'
	${REINPLACE_CMD} -e 's@ EOWNERDEAD,@@g' -e 's@ ENOTRECOVERABLE,@@g' \
		${WRKSRC}/cargo-crates/ffmpeg-next-*/src/util/error.rs
MK1
mk set IGNORE "unmaintained, please request fixing to users mailing list"
