port cad/klayout
type port
reason "auto-converted from compat (Makefile.DragonFly + dragonfly/)"
target @any

mk target set dfly-patch <<'MK1'
	${REINPLACE_CMD} -e 's@-Wno-reserved-user-defined-literal@@g'	\
			 -e 's@-pedantic@@g' -e 's@-Wsign-promo@-Wno-parentheses@g'	\
		${WRKSRC}/src/klayout.pri
MK1
mk set IGNORE "unmaintained, please request fixing to users mailing list"
file materialize dragonfly/patch-src_tl_tl_tlFileUtils.cc -> dragonfly/patch-src_tl_tl_tlFileUtils.cc
