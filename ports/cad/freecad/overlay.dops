port cad/freecad
type port
reason "auto-converted from compat (Makefile.DragonFly + dragonfly/)"
target @any

mk set LIB_DEPENDS "${LIB_DEPENDS:Nlibmpi*}"
mk set CMAKE_ARGS "${CMAKE_ARGS:N-DOPENMPI_INCLUDE_DIRS*}"
mk set IGNORE "unmaintained, please request fixing to users mailing list"
file materialize dragonfly/patch-src_3rdParty_libE57Format_src_CheckedFile.cpp -> dragonfly/patch-src_3rdParty_libE57Format_src_CheckedFile.cpp
file materialize dragonfly/patch-src_3rdParty_salomesmesh_CMakeLists.txt -> dragonfly/patch-src_3rdParty_salomesmesh_CMakeLists.txt
file materialize dragonfly/patch-src_Base_FileInfo.cpp -> dragonfly/patch-src_Base_FileInfo.cpp
file materialize dragonfly/patch-src_FCConfig.h -> dragonfly/patch-src_FCConfig.h
