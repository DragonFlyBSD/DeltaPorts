port biology/molden
type port
reason "auto-converted from compat (Makefile.DragonFly + dragonfly/)"
target @any

mk add LDFLAGS "-L${LOCALBASE}/lib"
mk target set dfly-patch <<'MK1'
	${REINPLACE_CMD} -e 's@/usr/include/[^[:space:]]*\.h@@g'	\
		${WRKSRC}/surf/Makefile
MK1
mk set IGNORE "unmaintained, please request fixing to users mailing list"
file materialize dragonfly/patch-ambfor_alloc.c -> dragonfly/patch-ambfor_alloc.c
file materialize dragonfly/patch-xwin.c -> dragonfly/patch-xwin.c
