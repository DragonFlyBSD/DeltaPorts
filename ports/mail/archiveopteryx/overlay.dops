port mail/archiveopteryx
type port
reason "auto-converted from compat (Makefile.DragonFly + dragonfly/)"
target @any

mk target set dfly-patch <<'MK1'
	${REINPLACE_CMD} -e 's@CLANG@CLANG_NOT@g'	\
		${WRKSRC}/Jamrules
	${REINPLACE_CMD} -e 's@-Werror@@g'		\
		${WRKSRC}/Jamsettings ${WRKSRC}/Makefile
MK1
file materialize dragonfly/patch-core_file.cpp -> dragonfly/patch-core_file.cpp
file materialize dragonfly/patch-db_query.cpp -> dragonfly/patch-db_query.cpp
