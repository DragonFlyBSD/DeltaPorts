port mail/rspamd
type port
reason "set GCC version and strip LUAJIT from OPTIONS_DEFAULT and OPTIONS_DEFAULT_x86_64"
target @any

mk set USE_GCC_VERSION "${GCC_DEFAULT}"
mk eval OPTIONS_DEFAULT "${OPTIONS_DEFAULT:NLUAJIT}"
mk eval OPTIONS_DEFAULT_x86_64 "${OPTIONS_DEFAULT_x86_64:NLUAJIT}"
file materialize dragonfly/patch-contrib_librdns_rdns.h -> dragonfly/patch-contrib_librdns_rdns.h
file materialize dragonfly/patch-contrib_t1ha_t1ha__bits.h -> dragonfly/patch-contrib_t1ha_t1ha__bits.h
