port archivers/rpm4
type port
reason "remove elfutils dep, add configure workaround, materialize DragonFly patches"
target @any

patch apply diffs/Makefile.diff

text line-remove file pkg-plist exact "lib/rpm/elfdeps" on-missing noop

file materialize dragonfly/patch-misc_fts.c -> dragonfly/patch-misc_fts.c
file materialize dragonfly/patch-rpmio_rpmio.c -> dragonfly/patch-rpmio_rpmio.c
