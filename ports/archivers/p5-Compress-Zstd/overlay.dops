port archivers/p5-Compress-Zstd
type port
reason "auto-converted from compat (Makefile.DragonFly + dragonfly/)"
target @any

mk set MAKE_JOBS_UNSAFE "yes"
mk target set dfly-patch <<'MK1'
	${REINPLACE_CMD} -e 's@CCVER@zstd&@g' \
		${WRKSRC}/ext/zstd/lib/Makefile
MK1
file materialize dragonfly/patch-builder_MyBuilder.pm -> dragonfly/patch-builder_MyBuilder.pm
