port archivers/dpkg
type port
reason "auto-converted from Makefile.DragonFly"
target @any

mk set CONFIGURE_ARGS "${CONFIGURE_ARGS:N--with-libmd} --with-libmd=no"
mk add CONFIGURE_ENV "ac_cv_header_md5_h=no"
mk target set dfly-patch <<'MK1'
	${REINPLACE_CMD} -e 's|<md5.h>|"compat/md5.h"|' \
		${WRKSRC}/lib/dpkg/buffer.c
MK1
