port databases/libgda5
type port
reason "conditionally patch configure to add dragonfly JDBC support"
target @any

mk block set condition "${LIBGDA5_SLAVE}==jdbc" <<'MK'
dfly-patch:
	${REINPLACE_CMD} -e 's@linux solaris@& dragonfly@g' \
			 -e 's@lib/server@& -L$${JAVA_HOME}/lib/amd64/server -Wl,-rpath,$${JAVA_HOME}/lib/amd64/server@g' \
		${WRKSRC}/configure
MK
