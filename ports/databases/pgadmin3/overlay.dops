port databases/pgadmin3
type port
reason "add gsed dep for sed byte-sequence issue; patch Makefile.in; mark unmaintained; dragonfly patches"
target @any

mk add BUILD_DEPENDS "gsed:textproc/gsed"
mk set DFLY_UNMAINTAINED "yes"

mk target set dfly-patch <<'MK'
	${REINPLACE_CMD} -e '/iso8859_1/s@[[:<:]]sed[[:>:]]@gsed@g' \
                ${WRKSRC}/Makefile.in
MK

file materialize dragonfly/patch-libressl-compat -> dragonfly/patch-libressl-compat
