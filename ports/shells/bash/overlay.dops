port shells/bash
type port
reason "add ncurses, set TERMCAP_LIB, update pkg-message for DragonFly, dragonfly readline patch"
target @any

mk add USES ncurses
mk add MAKE_ARGS "TERMCAP_LIB=-ltinfo"
patch apply diffs/files_pkg-message.in.diff

file materialize dragonfly/patch-lib_readline_terminal.c -> dragonfly/patch-lib_readline_terminal.c
