port ftp/curl
type port
reason "auto-converted from compat (fragment + diffs/)"
target @any

mk eval OPTIONS_DEFAULT "${OPTIONS_DEFAULT:NGSSAPI_MIT} GSSAPI_NONE"
mk set OPTIONS_DEFAULT "ALTSVC COOKIES DICT FTP GOPHER HTTP HTTP2 IMAP IPFS LIBSSH2 NTLM OPENSSL POP3 PROXY PSL RTSP SMTP STATIC TELNET TFTP THREADED_RESOLVER TLS_SRP WEBSOCKET ZSTD"
