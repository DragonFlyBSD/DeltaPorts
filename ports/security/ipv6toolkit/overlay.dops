port security/ipv6toolkit
type port
reason "auto-converted from compat (Makefile.DragonFly + dragonfly/)"
target @any

mk set MAKE_JOBS_UNSAFE "yes"
mk add MAKE_ENV "CWARNFLAGS=-fcommon"
file materialize dragonfly/patch-tools_libipv6.c -> dragonfly/patch-tools_libipv6.c
file materialize dragonfly/patch-tools_libipv6.h -> dragonfly/patch-tools_libipv6.h
