	${REINPLACE_CMD} -e 's@[[:<:]]_KERNEL[[:>:]]@_KERNEL_STRUCTURES@g' \
		${WRKSRC}/main.h ${WRKSRC}/resolve.c ${WRKSRC}/utils.c ${WRKSRC}/whois.c
MK1
file materialize dragonfly/patch-net.c -> dragonfly/patch-net.c
