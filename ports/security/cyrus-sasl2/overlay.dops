port security/cyrus-sasl2
type port
reason "auto-converted from Makefile.DragonFly"
target @any

mk set MAKE_JOBS_UNSAFE "yes"
mk eval OPTIONS_DEFAULT "${OPTIONS_DEFAULT:NOTP} SSL"
mk add USES "ssl"
mk add CONFIGURE_ARGS "--with-openssl=${OPENSSLBASE}"
mk add CFLAGS "-I${OPENSSLINC}"
mk add LDFLAGS "-L${OPENSSLLIB}"
