port security/openssl-unsafe
type port
reason "exclude SCTP, filter CONFIGURE_ARGS and CFLAGS, dragonfly config patch"
target @any

mk add OPTIONS_EXCLUDE SCTP
mk eval CONFIGURE_ARGS "${CONFIGURE_ARGS:Nsctp}"
mk eval CFLAGS "${CFLAGS:N-Werror:N-Qunused-arguments}"

file materialize dragonfly/patch-config -> dragonfly/patch-config
