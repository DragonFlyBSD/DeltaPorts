port security/snort3
type port
reason "libpcap.so versioned dep, dragonfly source patches"
target @any

text replace-once file Makefile from "		libpcap.so:net/libpcap \\" to "		libpcap.so.1:net/libpcap \\"

file materialize dragonfly/patch-src_loggers_alert__unixsock.cc -> dragonfly/patch-src_loggers_alert__unixsock.cc
