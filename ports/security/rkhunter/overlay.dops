port security/rkhunter
type port
reason "auto-converted from compat (Makefile.DragonFly + dragonfly/)"
target @any

mk eval OPTIONS_DEFAULT "${OPTIONS_DEFAULT:NLSOF}"
mk target set dfly-patch <<'MK1'
	${REINPLACE_CMD} -e 's@/lib64@/lib@g' \
		${WRKSRC}/installer.sh
MK1
file materialize dragonfly/patch-files_rkhunter -> dragonfly/patch-files_rkhunter
